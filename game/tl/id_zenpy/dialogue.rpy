# ARQUIVO: game/script.rpy DIALOGOS: 360


#game/script.rpy:170
translate id_zenpy intro_mansion_daf17248:

#   "On a cold winter night, a 999 emergency call reports a crime at the Mansion of Mazes."
    "Pada malam yang dingin, sebuah panggilan darurat 999 melaporkan ada kejahatan di Mansion of Mazes."

#game/script.rpy:171
translate id_zenpy intro_mansion_adfdb1cc:

#   "Jewellery and paintings have vanished."
    "Perhiasan dan lukisan berharga telah hilang."

#game/script.rpy:172
translate id_zenpy intro_mansion_486c9ed7:

#   "Footprints mark the hall…"
    "Jejak kaki tercetak di aula…"

#game/script.rpy:173
translate id_zenpy intro_mansion_77d8515b:

#   "Yet there are no signs of anyone entering or leaving."
    "Namun anehnya, tidak ada tanda-tanda siapa pun yang masuk atau keluar."

#game/script.rpy:175
translate id_zenpy intro_mansion_5ac435e7:

#   "The police are baffled. And now, they have asked you to solve the mystery."
    "Polisi pun kebingungan. Kini, mereka meminta bantuanmu untuk memecahkan misteri ini."

#game/script.rpy:183
translate id_zenpy intro_mansion_588dcd42:

#   "You are in the Grand Hall."
    "Kamu berada di Aula Besar."

#game/script.rpy:187
translate id_zenpy intro_mansion_1c91d287:

#   "There is a small table in front of you. On it is a letter addressed to you!"
    "Ada sebuah meja kecil di depanmu. Di atasnya terdapat surat yang ditujukan untukmu!"

#game/script.rpy:193
translate id_zenpy intro_mansion_3f20713b:

#   "You look around and see shapes on the walls where priceless paintings once hung now they have been stolen."
    "Kamu melihat sekeliling dan menemukan bekas-bekas di dinding tempat lukisan-lukisan berharga pernah tergantung — kini semuanya sudah dicuri."

#game/script.rpy:194
translate id_zenpy intro_mansion_71bb33e2:

#   "You make a note of the shapes in your notebook. They might be important!"
    "Kamu mencatat bentuk-bentuk itu di buku catatanmu. Siapa tahu berguna nanti!"

#game/script.rpy:210
translate id_zenpy mysterious_helper_ccff0889:

#   "Don't be afraid. Help is always nearby. Just follow the instructions one at a time, and see how far you get."
    "Jangan takut. Bantuan selalu ada di dekatmu. Ikuti petunjuknya satu per satu, dan lihat seberapa jauh kamu bisa maju."

#game/script.rpy:214
translate id_zenpy mysterious_helper_1fee3fb3:

#   "Now make your way to the Grand Hall to begin your adventure. Good luck!"
    "Sekarang pergilah ke Aula Besar untuk memulai petualanganmu. Semoga beruntung!"

#game/script.rpy:219
translate id_zenpy mysterious_helper_588dcd42:

#   "You are in the Grand Hall."
    "Kamu berada di Aula Besar."

#game/script.rpy:223
translate id_zenpy mysterious_helper_1c91d287:

#   "There is a small table in front of you. On it is a letter addressed to you!"
    "Ada sebuah meja kecil di depanmu. Di atasnya terdapat surat yang ditujukan untukmu!"

#game/script.rpy:229
translate id_zenpy mysterious_helper_3f20713b:

#   "You look around and see shapes on the walls where priceless paintings once hung now they have been stolen."
    "Kamu melihat sekeliling dan menemukan bekas-bekas di dinding tempat lukisan-lukisan berharga pernah tergantung — kini semuanya sudah dicuri."

#game/script.rpy:230
translate id_zenpy mysterious_helper_71bb33e2:

#   "You make a note of the shapes in your notebook. They might be important!"
    "Kamu mencatat bentuk-bentuk itu di buku catatanmu. Siapa tahu berguna nanti!"

#game/script.rpy:240
translate id_zenpy main_hall_f0bc32a8:

#   "You see suspicious footprints on the floor. They lead off in four directions."
    "Kamu melihat jejak kaki yang mencurigakan di lantai. Jejaknya mengarah ke empat arah yang berbeda."

#game/script.rpy:243
translate id_zenpy main_hall_2b959c48:

#   "Then you hear a floorboard creak."
    "Lalu kamu mendengar suara papan lantai yang berderit."

#game/script.rpy:244
translate id_zenpy main_hall_3acc3e01:

#   "The sound came from the top of the stairs!"
    "Suara itu berasal dari atas tangga!"

#game/script.rpy:254
translate id_zenpy main_hall_6432304c:

#   "You step through the library doors."
    "Kamu melangkah masuk melewati pintu perpustakaan."

#game/script.rpy:257
translate id_zenpy main_hall_967e12f3:

#   "Suddenly it feels cold. The wind whistles down the chimney. You start to feel scared."
    "Tiba-tiba terasa dingin sekali. Angin bersiul turun dari cerobong asap. Kamu mulai merasa takut."

#game/script.rpy:260
translate id_zenpy main_hall_ceb9b528:

#   "But then you hear a friendly woof. You feel better again."
    "Tapi kemudian kamu mendengar gonggongan yang ramah. Kamu pun merasa lebih tenang."

#game/script.rpy:263
translate id_zenpy main_hall_3632720a:

#   "You check the windows. They are locked. The burglars could not enter or leave that way."
    "Kamu memeriksa jendela-jendelanya. Semuanya terkunci. Para pencuri tidak mungkin masuk atau keluar lewat sini."

#game/script.rpy:265
translate id_zenpy main_hall_d27bb0fc:

#   "Then you spot the safe. It's open! The jewels it held have been stolen with the paintings!"
    "Lalu kamu melihat brankas. Terbuka! Perhisan yang ada di dalamnya sudah dicuri bersama lukisan-lukisannya!"

#game/script.rpy:269
translate id_zenpy main_hall_a7b84e90:

#   "A note left inside the safe tells you what to do…"
    "Sebuah catatan yang tertinggal di dalam brankas memberitahumu apa yang harus dilakukan…"

#game/script.rpy:281
translate id_zenpy main_hall_07fd9507:

#   "You open the door labelled 'Cellars'. You see the footprints going down the stairs. The burglars have been down there!"
    "Kamu membuka pintu berlabel 'Gudang Bawah'. Kamu melihat jejak kaki yang menuruni tangga. Para pencuri pernah turun ke sana!"

#game/script.rpy:284
translate id_zenpy main_hall_e3db0242:

#   "The way ahead is dimly lit by flickering light bulbs hanging on fraying wires."
    "Jalan di depan hanya diterangi cahaya redup dari lampu-lampu yang berkedip-kedip, tergantung pada kabel yang sudah usang."

#game/script.rpy:288
translate id_zenpy main_hall_c0723bb1:

#   "On the first step you find a ball of string resting on a note. You pick up the string and read the note…"
    "Di anak tangga pertama, kamu menemukan gulungan tali yang diletakkan di atas sebuah catatan. Kamu mengambil talinya dan membaca catatannya…"

#game/script.rpy:294
translate id_zenpy main_hall_52eed65c:

#   "You've heard of the Minotaur. It was a mythical beast. It had a man's body and a bull's head! But there can't be one down here, can there?"
    "Kamu pernah mendengar tentang Minotaur — makhluk mitos yang punya tubuh manusia tapi berkepala banteng! Tapi masa ada Minotaur di sini... kan?"

#game/script.rpy:298
translate id_zenpy main_hall_d101ab4d:

#   "You tie one end of the string to the doorknob, and set off down the stairs. You unwind the string as you go."
    "Kamu mengikat salah satu ujung tali ke kenop pintu, lalu mulai menuruni tangga. Talinya kamu ulurkan pelan-pelan sambil berjalan."

#game/script.rpy:301
translate id_zenpy main_hall_7a134566:

#   "Soft footsteps follow close behind but somehow you know they are friendly."
    "Langkah kaki yang lembut mengikutimu dari belakang, tapi entah kenapa kamu tahu itu bukan bahaya."

#game/script.rpy:311
translate id_zenpy main_hall_32491173:

#   "The footprints lead you down a flight of steps to a large door labelled 'Kitchens'. The smell of fresh bread wafts through the door."
    "Jejak kaki itu membawamu menuruni anak tangga menuju pintu besar berlabel 'Dapur'. Aroma roti segar tercium dari balik pintu."

#game/script.rpy:314
translate id_zenpy main_hall_270b33d8:

#   "Then you hear something it sounds like an animal licking its lips!"
    "Lalu kamu mendengar sesuatu — seperti suara hewan yang menjilat bibirnya!"

#game/script.rpy:316
translate id_zenpy main_hall_a3f949d7:

#   "The kitchens are huge. There is a great open fireplace. There are banks of ovens, huge wooden tables and racks of pots and pans."
    "Dapurnya sangat luas. Ada perapian besar yang terbuka, deretan oven, meja kayu yang besar-besar, dan rak-rak panci serta wajan."

#game/script.rpy:320
translate id_zenpy main_hall_e488c899:

#   "Just inside the door is a notice board with meal times and menus. Someone has pinned up a letter addressed to you!"
    "Tepat di dalam pintu ada papan pengumuman berisi jadwal makan dan menu. Seseorang telah menempelkan surat yang ditujukan untukmu!"

#game/script.rpy:338
translate id_zenpy puzzle_1_ad37b918:

#   "You look around for clues. Then you see patterns carved around the fireplace."
    "Kamu mencari-cari petunjuk. Lalu kamu melihat ukiran pola di sekitar perapian."

#game/script.rpy:340
translate id_zenpy puzzle_1_c3505ac1:

#   "They are not as dusty as the rest of the room. Someone has been touching them! You step closer. The patterns are triangles!"
    "Ukiran itu tidak berdebu seperti bagian ruangan lainnya. Berarti seseorang baru saja menyentuhnya! Kamu mendekat. Ternyata polanya berbentuk segitiga!"

#game/script.rpy:354
translate id_zenpy puzzle_1_c29f5f75:

#   "You see fingerprints on triangle B, so you press it."
    "Kamu melihat sidik jari di segitiga B, jadi kamu menekannya."

#game/script.rpy:362
translate id_zenpy puzzle_1_a1b5152d:

#   "The bookcase to the right of the fireplace swings open. It's a secret door. There is a hiding place behind the wall. You made the right choice!"
    "Rak buku di sebelah kanan perapian tiba-tiba terbuka. Ternyata itu pintu rahasia! Ada ruang tersembunyi di balik dinding. Kamu memilih dengan benar!"

#game/script.rpy:375
translate id_zenpy blast_of_flame_1085edf0:

#   "You press triangle A. A blast of flame roars from the fireplace! Strong teeth grab your belt and pull you to safety. Who was that?"
    "Kamu menekan segitiga A. Tiba-tiba semburan api besar menyembur dari perapian! Gigi yang kuat mencengkeram ikat pinggangmu dan menarikmu ke tempat aman. Siapa itu?"

#game/script.rpy:379
translate id_zenpy blast_of_flame_a813f48d:

#   "It was the wrong triangle. An equilateral triangle has three equal sides and three equal angles."
    "Kamu memilih segitiga yang salah. Segitiga sama sisi punya tiga sisi yang sama panjang dan tiga sudut yang sama besar."

#game/script.rpy:380
translate id_zenpy blast_of_flame_e051147f:

#   "Triangle A has only two equal sides and angles. The third side and angle are different from the others. It is an isosceles triangle."
    "Segitiga A hanya punya dua sisi dan dua sudut yang sama. Sisi dan sudut ketiganya berbeda. Itu namanya segitiga sama kaki."

#game/script.rpy:390
translate id_zenpy puzzle_2_2aeb0776:

#   "You step through the doorway into the hiding place. It's a tiny room with walls made from stone blocks."
    "Kamu masuk melewati pintu menuju tempat persembunyian itu. Ternyata itu ruangan kecil dengan dinding yang terbuat dari balok-balok batu."

#game/script.rpy:394
translate id_zenpy puzzle_2_7fee9f70:

#   "There is a stool in the centre. On the stool is a note..."
    "Ada bangku kecil di tengah ruangan. Di atas bangku itu terdapat sebuah catatan..."

#game/script.rpy:398
translate id_zenpy puzzle_2_33709447:

#   "You sit on the stool and look around."
    "Kamu duduk di bangku itu dan melihat sekeliling."

#game/script.rpy:399
translate id_zenpy puzzle_2_7d26fca7:

#   "Someone has scratched lines on the walls perhaps centuries ago when they were hiding from highwaymen! The lines make shapes around the stones."
    "Seseorang telah mengukir garis-garis di dinding — mungkin ratusan tahun lalu ketika mereka bersembunyi dari para perampok! Garis-garis itu membentuk pola di sekeliling batu-batunya."

#game/script.rpy:407
translate id_zenpy puzzle_2_bb0d4e9d:

#   "The stone at the centre of the shape is loose. You pull it out with your fingertips. Someone has hidden a slip of paper in the space behind. There is something written"
    "Batu di tengah pola itu terasa longgar. Kamu menariknya keluar dengan ujung jari. Di celah belakangnya tersembunyi secarik kertas. Ada tulisan di sana..."

#game/script.rpy:410
translate id_zenpy puzzle_2_12ac3e21:

#   "It's the title of a book! But what does E,5 mean?"
    "Itu judul sebuah buku! Tapi, apa ya artinya E,5?"

#game/script.rpy:425
translate id_zenpy puzzle_3_d9e97473:

#   "You step back into the library. Now you must find the book. There are thousands of them!"
    "Kamu kembali ke perpustakaan. Sekarang kamu harus menemukan bukunya. Tapi ada ribuan buku di sini!"

#game/script.rpy:426
translate id_zenpy puzzle_3_4a634600:

#   "They are so old and dusty you can't read the titles on their spines. Finding Through the Looking Glass is going to take forever!"
    "Buku-bukunya sangat tua dan berdebu sehingga kamu tidak bisa membaca judulnya. Mencari 'Dunia di Balik Cermin' rasanya akan butuh waktu selamanya!"

#game/script.rpy:430
translate id_zenpy puzzle_3_94a9fdfb:

#   "Then you see that the bookcases and shelves are marked with letters and numbers. Some are so worn you cannot read them, but you can work out where E.5 is!"
    "Lalu kamu melihat bahwa rak-rak buku itu diberi tanda huruf dan angka. Beberapa sudah sangat pudar, tapi kamu tetap bisa mencari tahu dimana letak E.5!"

#game/script.rpy:440
translate id_zenpy puzzle_3_03712e6f:

#   "You start to take down the books from shelf X. The fourth one you open is Through the Looking Glass you chose the correct shelf!"
    "Kamu mulai mengambil buku-buku dari rak X. Buku keempat yang kamu buka adalah Dunia di Balik Cermin — kamu memilih rak yang tepat!"

#game/script.rpy:451
translate id_zenpy snake_strike_5ebe7f86:

#   "The stone at the centre of the shape is loose. You pull it out with your fingertips."
    "Batu di tengah pola itu terasa longgar. Kamu menariknya keluar dengan ujung jari."

#game/script.rpy:456
translate id_zenpy snake_strike_c06ed97e:

#   "In the dark space behind you see a pair of bright eyes and the flicker of a forked tongue."
    "Di celah gelap di baliknya, kamu melihat sepasang mata yang berkilat dan lidah bercabang yang bergerak-gerak."

#game/script.rpy:457
translate id_zenpy snake_strike_2cfb21bd:

#   "There's a snake in there! Quickly, before the snake can strike, you push the stone back."
    "Ada ular di sana! Dengan cepat, sebelum ular itu sempat menyerang, kamu mendorong batu itu kembali ke tempatnya."

#game/script.rpy:460
translate id_zenpy snake_strike_c11071c2:

#   "You chose a shape with eight sides that's an octagon. How many sides does a hexagon have?"
    "Kamu memilih bentuk yang memiliki delapan sisi — itu adalah segi delapan. Lalu, berapa sisi yang dimiliki segi enam?"

#game/script.rpy:471
translate id_zenpy puzzle_4_daa400be:

#   "Inside the cover of Through the Looking Glass, you find a folded sheet of paper. It's another clue!"
    "Di dalam sampul 'Dunia di Balik Cermin', kamu menemukan selembar kertas terlipat. Itu petunjuk berikutnya!"

#game/script.rpy:477
translate id_zenpy puzzle_4_b5be64da:

#   "You look at the first three books you took down. Each has a shape on the cover. Which shape is not symmetrical? That's the book you must open."
    "Kamu melihat tiga buku pertama yang kamu ambil. Masing-masing memiliki bentuk di sampulnya. Bentuk manakah yang tidak simetris? Itulah buku yang harus kamu buka."

#game/script.rpy:483
translate id_zenpy puzzle_4_a65e6ad6:

#   "You can see that each side of the heart would look identical if held against a mirror. It has a line of symmetry down the middle."
    "Kamu bisa melihat bahwa kedua sisi hati akan terlihat sama persis jika dicerminkan. Hati punya garis simetri tepat di tengahnya."

#game/script.rpy:484
translate id_zenpy puzzle_4_022158fb:

#   "The left half is a mirror image of the right. But which of shapes A and B is not symmetrical?"
    "Bagian kiri adalah bayangan cermin dari bagian kanan. Tapi, manakah di antara bentuk A dan B yang tidak simetris?"

#game/script.rpy:501
translate id_zenpy puzzle_4_a1cce2a6:

#   "You open the cover. The pages have been cut to make a secret hiding place inside."
    "Kamu membuka sampulnya. Halaman-halamannya telah dipotong untuk membuat ruang persembunyian rahasia di dalamnya."

#game/script.rpy:502
translate id_zenpy puzzle_4_b1901f1e:

#   "There is a large iron key hidden in the space. This must be the key in the letter!"
    "Ada kunci besi besar tersembunyi di dalamnya. Ini pasti kunci yang disebutkan di surat itu!"

#game/script.rpy:504
translate id_zenpy puzzle_4_4bfad116:

#   "You've chosen the correct book! You slip the key into your bag."
    "Kamu memilih buku yang benar! Kamu memasukkan kunci itu ke dalam tasmu."

#game/script.rpy:516
translate id_zenpy crashed_bookcase_63f6dd19:

#   "You reach up to take the books down from shelf Y."
    "Kamu mengulurkan tangan untuk mengambil buku-buku dari rak Y."

#game/script.rpy:519
translate id_zenpy crashed_bookcase_2f68ef02:

#   "As you pull out the first book, a loud bark makes you jump to one side."
    "Saat kamu menarik buku pertama, gonggongan keras mengejutkanmu dan kamu melompat ke samping."

#game/script.rpy:524
translate id_zenpy crashed_bookcase_589188d0:

#   "The bookcase topples and crashes to the floor just where you had been standing. That was close! Where did that bark come from?"
    "Rak buku itu roboh dan jatuh berdebum tepat di tempat kamu berdiri tadi. Nyaris saja! Dari mana gonggongan tadi berasal?"

#game/script.rpy:528
translate id_zenpy crashed_bookcase_2a487139:

#   "You chose the wrong shelf. The E and the 5 are coordinates. Count along the book cases A, B, C, D, E. Count up the shelves 1, 2, 3, 4, 5."
    "Kamu memilih rak yang salah. E dan 5 adalah koordinat. Hitung rak bukunya dari A, B, C, D, E. Lalu hitung tingkat raknya dari 1, 2, 3, 4, 5."

#game/script.rpy:539
translate id_zenpy giant_centipede_9637f2e3:

#   "You open the book. The pages have been cut to make a secret space inside. There is something in there."
    "Kamu membuka buku itu. Halaman-halamannya telah dipotong untuk membuat ruang rahasia di dalamnya. Ada sesuatu di sana."

#game/script.rpy:540
translate id_zenpy giant_centipede_d9c50160:

#   "It's a giant centipede! It starts to crawl towards your hand. Then a loud bark makes you jump into action. You slam the book shut."
    "Kelabang raksasa! Ia mulai merayap ke arah tanganmu. Lalu gonggongan keras mengejutkanmu dan kamu langsung membanting buku itu hingga tertutup."

#game/script.rpy:543
translate id_zenpy giant_centipede_4cd6d10d:

#   "You chose the wrong book! The face is symmetrical. It has a line of symmetry like the heart"
    "Kamu memilih buku yang salah! Wajah itu simetris. Ia punya garis simetri seperti hati."

#game/script.rpy:552
translate id_zenpy puzzle_5_0c03ec79:

#   "Now you have the key you must find the 'ancient shape'. What can it be?"
    "Sekarang kamu sudah punya kuncinya, tapi kamu harus menemukan 'bentuk kuno' itu dulu. Kira-kira apa ya?"

#game/script.rpy:553
translate id_zenpy puzzle_5_3a846c2e:

#   "You look around the library for more clues."
    "Kamu melihat sekeliling perpustakaan untuk mencari petunjuk berikutnya."

#game/script.rpy:557
translate id_zenpy puzzle_5_0a30e2d4:

#   "There is a large desk in the centre of the room. It is covered with drawings and plans."
    "Ada meja besar di tengah ruangan. Permukaannya penuh dengan gambar dan denah."

#game/script.rpy:558
translate id_zenpy puzzle_5_b810fe28:

#   "You take a closer look. One plan seems to be for the library you are standing in! Someone has scribbled a note in one corner…"
    "Kamu melihat lebih dekat. Salah satu denah tampaknya adalah denah perpustakaan tempat kamu berdiri sekarang! Seseorang menulis catatan kecil di salah satu sudutnya…"

#game/script.rpy:559
translate id_zenpy puzzle_5_d2eaac07:

#   "There is a secret trapdoor! Something important could be hidden there. And the plan shows all the carpets in the room."
    "Ada pintu jebakan rahasia! Mungkin ada sesuatu yang penting tersembunyi di sana. Dan denah itu menunjukkan semua karpet di ruangan ini."

#game/script.rpy:560
translate id_zenpy puzzle_5_d460acb6:

#   "Which one should you look under to find the trapdoor?"
    "Karpet yang mana yang harus kamu angkat untuk menemukan pintu jebakan itu?"

#game/script.rpy:576
translate id_zenpy puzzle_5_bf74b0e3:

#   "You roll up carpet B. There is a trapdoor in the floor beneath! You chose the correct carpet. Its perimeter is 2 m + 1 m + 2 m + 1 m = 6 m."
    "Kamu menggulung karpet B. Ada pintu jebakan di lantai bawahnya! Kamu memilih karpet yang tepat. Kelilingnya adalah 2 m + 1 m + 2 m + 1 m = 6 m."

#game/script.rpy:585
translate id_zenpy strange_fumes_dad3588b:

#   "You roll up carpet A."
    "Kamu menggulung karpet A."

#game/script.rpy:588
translate id_zenpy strange_fumes_a71acf39:

#   "Strange fumes start to rise from between the floorboards."
    "Asap aneh mulai mengepul dari celah-celah papan lantai."

#game/script.rpy:589
translate id_zenpy strange_fumes_f06e9675:

#   "You are passing out! Then something pushes the carpet back into place."
    "Kamu hampir pingsan! Lalu sesuatu mendorong karpet itu kembali ke tempatnya."

#game/script.rpy:593
translate id_zenpy strange_fumes_6c9378d8:

#   "You feel a wet tongue lick your face, and you come around."
    "Kamu merasakan lidah basah menjilat wajahmu, dan kamu pun tersadar kembali."

#game/script.rpy:595
translate id_zenpy strange_fumes_5fec38ea:

#   "You chose the wrong carpet! The perimeter is the distance all the way around the shape."
    "Kamu memilih karpet yang salah! Keliling adalah jarak mengelilingi seluruh tepi suatu bangun."

#game/script.rpy:598
translate id_zenpy strange_fumes_b9bd9b61:

#   "The diagram below shows how to calculate the perimeter of the carpet. Try this with carpet B."
    "Gambar di bawah menunjukkan cara menghitung keliling karpet. Coba hitung keliling karpet B!"

#game/script.rpy:599
translate id_zenpy strange_fumes_fc1dfcf3:

#   "Perimeter = 2 m + 2m + 2m + 2 m = 8m"
    "Keliling = 2 m + 2 m + 2 m + 2 m = 8 m"

#game/script.rpy:611
translate id_zenpy puzzle_6_a8f0038d:

#   "The trapdoor does not have a handle. It is made from squares of wood like a chess board. Some of the squares are coloured to make patterns."
    "Pintu jebakan itu tidak memiliki gagang. Terbuat dari kotak-kotak kayu seperti papan catur. Beberapa kotak diwarnai membentuk pola-pola tertentu."

#game/script.rpy:617
translate id_zenpy puzzle_6_2744f057:

#   "Then you spot a message scratched into the floorboards…"
    "Lalu kamu melihat sebuah pesan yang tergores di papan lantai…"

#game/script.rpy:633
translate id_zenpy puzzle_6_ae8b948b:

#   "It's the correct sequence. The trapdoor swings smoothly up to reveal a dark hole. There is an iron ladder going down below."
    "Itu urutan yang benar. Pintu jebakan terbuka dengan mulus dan memperlihatkan sebuah lubang gelap. Ada tangga besi yang mengarah ke bawah."

#game/script.rpy:637
translate id_zenpy puzzle_6_dcc92c8b:

#   "You climb down the ladder into the dark. There are 20 rungs before you reach a cold stone floor. It's a good job you didn't fall!"
    "Kamu menuruni tangga ke dalam kegelapan. Ada 20 anak tangga sebelum kamu menginjak lantai batu yang dingin. Untung kamu tidak jatuh!"

#game/script.rpy:639
translate id_zenpy puzzle_6_5c5136d8:

#   "As you step off the ladder your foot touches something. It rolls away. You put your hand down and feel around."
    "Saat kamu turun dari tangga, kakimu menyentuh sesuatu. Benda itu menggelinding. Kamu meraba-raba lantai dengan tanganmu."

#game/script.rpy:640
translate id_zenpy puzzle_6_30958fab:

#   "It's a torch! You press the button and the torch lights up the room. It's an amazing sight!"
    "Sebuah senter! Kamu menekan tombolnya dan senter itu menerangi seluruh ruangan. Sungguh pemandangan yang menakjubkan!"

#game/script.rpy:646
translate id_zenpy puzzle_6_55606a75:

#   "The trapdoor slams shut above you. Now you are trapped!"
    "Pintu jebakan di atasmu tiba-tiba menutup keras. Kamu terjebak!"

#game/script.rpy:654
translate id_zenpy puzzle_7_752c7fb3:

#   "You are in a store room under the library."
    "Kamu berada di ruang penyimpanan di bawah perpustakaan."

#game/script.rpy:655
translate id_zenpy puzzle_7_97355fbf:

#   "There are boxes of books, and cabinets filled with strange objects a telescope, a brass microscope and other ancient scientific instruments."
    "Ada kotak-kotak berisi buku, dan lemari-lemari yang dipenuhi benda-benda aneh — teleskop, mikroskop kuningan, dan alat-alat ilmu pengetahuan kuno lainnya."

#game/script.rpy:656
translate id_zenpy puzzle_7_bcd35c86:

#   "Everything is covered with cobwebs. In one corner you see a set of mathematical shapes on a shelf."
    "Semuanya tertutup sarang laba-laba. Di salah satu sudut, kamu melihat sekumpulan bangun matematika di sebuah rak."

#game/script.rpy:657
translate id_zenpy puzzle_7_c4249543:

#   "You remember the description in the letter, 'an ancient shape with 5 faces and 8 edges'."
    "Kamu mengingat keterangan di surat tadi, 'bentuk kuno dengan 5 sisi dan 8 rusuk'."

#game/script.rpy:658
translate id_zenpy puzzle_7_c54c379b:

#   "Perhaps one of these is the shape you need? You start to count the faces and edges. You record the numbers in a table in your notebook…"
    "Mungkin salah satunya adalah bentuk yang kamu cari? Kamu mulai menghitung sisi dan rusuknya satu per satu, lalu mencatatnya dalam tabel di buku catatanmu…"

#game/script.rpy:660
translate id_zenpy puzzle_7_cdef6cbd:

#   "The first three shapes you check don't have the correct number of faces and edges. What about the two that are left?"
    "Tiga bentuk pertama yang kamu periksa tidak sesuai jumlah sisi dan rusuknya. Lalu bagaimana dengan dua bentuk yang tersisa?"

#game/script.rpy:677
translate id_zenpy dark_pit_2f7bfef5:

#   "You press the shapes in the order 2, 3, 1. Nothing happens, so you press harder."
    "Kamu menekan bentuk-bentuk itu dalam urutan 2, 3, 1. Tidak ada yang terjadi, jadi kamu menekannya lebih keras."

#game/script.rpy:682
translate id_zenpy dark_pit_af2b1437:

#   "Suddenly the trapdoor gives way. You are falling into a dark pit!"
    "Tiba-tiba pintu jebakan terbuka! Kamu jatuh ke dalam lubang yang gelap!"

#game/script.rpy:684
translate id_zenpy dark_pit_e439d27f:

#   "At the last minute strong teeth grab your shoes. You are dragged back from the danger."
    "Tepat pada saat terakhir, gigi yang kuat mencengkeram sepatumu. Kamu ditarik kembali dari bahaya."

#game/script.rpy:688
translate id_zenpy dark_pit_7d0e44a2:

#   "The trapdoor swings up and slams shut."
    "Pintu jebakan berayun ke atas dan menutup dengan keras."

#game/script.rpy:691
translate id_zenpy dark_pit_dabc6e5a:

#   "You pressed the shapes in the wrong order."
    "Kamu menekan bentuk-bentuknya dalam urutan yang salah."

#game/script.rpy:692
translate id_zenpy dark_pit_df625ef9:

#   "The area is the amount of surface a shape covers."
    "Luas adalah banyaknya permukaan yang ditempati oleh suatu bangun."

#game/script.rpy:693
translate id_zenpy dark_pit_20340509:

#   "When a shape is drawn on a grid you can find its area by counting the squares it surrounds."
    "Kalau suatu bangun digambar di atas kertas berkotak, kamu bisa mencari luasnya dengan menghitung kotak-kotak yang ada di dalamnya."

#game/script.rpy:701
translate id_zenpy exploded_pyramid_485dd61c:

#   "You reach for the triangle-based pyramid. As you grasp it, the pyramid starts to glow. It's getting hotter and hotter! You can't let go!"
    "Kamu meraih piramida segitiga. Saat kamu menggenggamnya, piramida itu mulai bersinar. Semakin lama semakin panas! Kamu tidak bisa melepaskannya!"

#game/script.rpy:704
translate id_zenpy exploded_pyramid_c4ceaa60:

#   "Sparks fly from its corners and your whole body starts to tingle and shake. Then something large leaps across the table, knocking the pyramid from your hand."
    "Percikan api menyembur dari sudut-sudutnya dan seluruh tubuhmu mulai kesemutan dan gemetar. Lalu sesuatu yang besar melompat ke meja, menjatuhkan piramida dari tanganmu."

#game/script.rpy:709
translate id_zenpy exploded_pyramid_adbe3e7e:

#   "Just in time - it explodes into a thousand pieces with a flash like lightning!"
    "Tepat pada waktunya — piramida itu meledak berkeping-keping dengan kilatan seperti petir!"

#game/script.rpy:711
translate id_zenpy exploded_pyramid_dcb1cf3d:

#   "You chose the wrong shape. A triangle-based pyramid has 4 faces and 6 sides."
    "Kamu memilih bentuk yang salah. Piramida segitiga memiliki 4 sisi dan 6 rusuk."

#game/script.rpy:722
translate id_zenpy puzzle_8_ff40442b:

#   "You pick up the square-based pyramid. It's heavy in your hand. You turn it around. There is a picture of the Sun and a message on one face."
    "Kamu mengambil piramida persegi. Berat juga di tanganmu. Kamu membalikkannya. Di salah satu sisinya ada gambar Matahari dan sebuah pesan."

#game/script.rpy:723
translate id_zenpy puzzle_8_4eae979e:

#   "It doesn't make sense! You understand that you will need the pyramid later on, but what's all that about a mummy's case and You look desperately around."
    "Pesan itu membingungkan! Kamu mengerti bahwa piramida ini pasti akan berguna nanti, tapi apa hubungannya dengan peti mumi? Kamu melihat sekeliling dengan penasaran."

#game/script.rpy:729
translate id_zenpy puzzle_8_150d1145:

#   "Then your torch shines on two large objects against the wall. They are Egyptian mummy cases! Egyptian mummies were placed inside them in the pyramids!"
    "Lalu sentermu menyinari dua benda besar yang bersandar di dinding. Itu peti mumi dari Mesir! Dulu, mumi Mesir disimpan di dalamnya di dalam piramida!"

#game/script.rpy:730
translate id_zenpy puzzle_8_f32d219b:

#   "You walk over to the mummy cases. They have strange symbols on the front. You recognize the symbols! They are mathematical nets."
    "Kamu berjalan mendekat ke peti-peti mumi itu. Ada simbol-simbol aneh di bagian depannya. Kamu mengenali simbol-simbol itu! Itu adalah jaring-jaring bangun matematika."

#game/script.rpy:731
translate id_zenpy puzzle_8_3f413d4a:

#   "If you draw them on card, you can cut them out and fold them to make solid shapes! One must be the net for a pyramid. That's the one you need."
    "Kalau digambar di atas kertas karton, jaring-jaring itu bisa dipotong dan dilipat menjadi bentuk tiga dimensi! Salah satunya pasti jaring-jaring piramida. Itulah yang kamu butuhkan."

#game/script.rpy:748
translate id_zenpy puzzle_8_ad01e3e5:

#   "Cautiously you reach forwards and open the lid. It's not a case at all. It's the entrance to a secret passage! You made the right choice."
    "Dengan hati-hati kamu meraih ke depan dan membuka tutupnya. Ternyata ini bukan peti biasa sama sekali. Ini adalah pintu masuk ke lorong rahasia! Kamu memilih dengan benar."

#game/script.rpy:755
translate id_zenpy puzzle_8_c1392156:

#   "You pop the pyramid in the bag with the key, shine your torch to show the way, and set off along the passage."
    "Kamu memasukkan piramida ke dalam tas bersama kunci, menyalakan senter untuk menerangi jalan, dan mulai berjalan menyusuri lorong."

#game/script.rpy:766
translate id_zenpy puzzle_9_79f0d5f3:

#   "Very soon the passage divides. Which way should you go?"
    "Tak lama kemudian lorong itu bercabang dua. Kamu harus pergi ke arah mana?"

#game/script.rpy:770
translate id_zenpy puzzle_9_7b15c0af:

#   "Then you see someone has chalked a message and a shape on the wall."
    "Lalu kamu melihat ada seseorang yang menulis pesan dan menggambar bentuk di dinding dengan kapur."

#game/script.rpy:771
translate id_zenpy puzzle_9_c879c261:

#   "You shine your torch along the two passageways. There is a pile of blocks in each one."
    "Kamu menyorotkan sentermu ke kedua lorong. Di masing-masing lorong ada tumpukan balok."

#game/script.rpy:772
translate id_zenpy puzzle_9_5a57320b:

#   "The piles are turned compared to your drawing. But one of them must have the blocks in the same pattern which will you choose?"
    "Tumpukan itu terlihat berbeda arah dibanding gambarmu. Tapi salah satunya pasti memiliki susunan balok yang sama — mana yang akan kamu pilih?"

#game/script.rpy:782
translate id_zenpy puzzle_9_a0adc72a:

#   "You take the left-hand passage. It's the correct passage!"
    "Kamu mengambil lorong sebelah kiri. Itu lorong yang benar!"

#game/script.rpy:787
translate id_zenpy puzzle_9_3646d365:

#   "Soon it opens into a small building surrounded by trees. You recognize where you are. You are in the Mansion garden not far from the front door."
    "Segera lorong itu berujung pada sebuah bangunan kecil yang dikelilingi pepohonan. Kamu tahu di mana kamu berada — ini taman Mansion, tidak jauh dari pintu depan."

#game/script.rpy:788
translate id_zenpy puzzle_9_0704eae9:

#   "You look back at the Mansion. You see a blaze of light in a window at the top of a turret."
    "Kamu menoleh ke arah Mansion. Kamu melihat cahaya terang di sebuah jendela di puncak salah satu menara."

#game/script.rpy:802
translate id_zenpy alive_mummy_875640c7:

#   "Cautiously, you reach forwards and open the lid."
    "Dengan hati-hati, kamu meraih ke depan dan membuka tutupnya."

#game/script.rpy:803
translate id_zenpy alive_mummy_45839b1c:

#   "Inside is a mummy wrapped in bandages. Its eyes glow red. Its bony hands reach out to grab your neck. It's going to pull you inside!"
    "Di dalamnya ada mumi yang dibalut perban! Matanya bersinar merah. Tangan-tangannya yang kurus menjangkau hendak mencengkeram lehermu. Ia akan menarikmu masuk!"

#game/script.rpy:807
translate id_zenpy alive_mummy_0892c281:

#   "Suddenly the mummy case slams shut. Someone has pushed the door and there are paw marks on it! The mummy is trapped inside again."
    "Tiba-tiba peti mumi itu menutup keras. Ada yang mendorong pintunya dan ada bekas cakar di sana! Mumi itu terjebak di dalamnya lagi."

#game/script.rpy:809
translate id_zenpy alive_mummy_f0e44df7:

#   "You chose the wrong case. This is the net for a prism, not a pyramid."
    "Kamu memilih peti yang salah. Itu adalah jaring-jaring prisma, bukan piramida."

#game/script.rpy:817
translate id_zenpy slippery_passage_c74f0d68:

#   "You take the right-hand passage. It is steep and slippery. Your shoes lose their grip. You start to slide, dislodging small pebbles along the way."
    "Kamu mengambil lorong sebelah kanan. Jalannya curam dan licin. Sepatumu mulai kehilangan pegangan. Kamu mulai tergelincir dan batu-batu kecil ikut tergelinding."

#game/script.rpy:818
translate id_zenpy slippery_passage_186b87ce:

#   "Then something grabs your collar and pulls you back to safety."
    "Lalu sesuatu mencengkeram kerah bajumu dan menarikmu kembali ke tempat aman."

#game/script.rpy:822
translate id_zenpy slippery_passage_49f1b9cb:

#   "You hear the pebbles splash into a deep underground pool, that could have been you!"
    "Kamu mendengar batu-batu kerikil itu tercebur ke kolam bawah tanah yang dalam — untung bukan kamu yang jatuh!"

#game/script.rpy:824
translate id_zenpy slippery_passage_5f61c18f:

#   "You chose the wrong shape. Try to turn the shapes in your mind to match the one in the drawing. Look at the block at the top of the shape, that will help you."
    "Kamu memilih bentuk yang salah. Coba bayangkan bentuk-bentuk itu berputar di pikiranmu agar cocok dengan gambar. Perhatikan balok di bagian paling atas — itu bisa membantumu."

#game/script.rpy:832
translate id_zenpy puzzle_10_52fe1198:

#   "Which turret was that? You will need to know when you go back inside."
    "Menara yang mana itu? Kamu perlu mengetahuinya sebelum masuk kembali ke dalam."

#game/script.rpy:836
translate id_zenpy puzzle_10_d7f95796:

#   "Then you see a design on the stone floor of the garden building. It's a plan of the Mansion."
    "Lalu kamu melihat sebuah gambar di lantai batu bangunan taman itu. Itu adalah denah Mansion."

#game/script.rpy:837
translate id_zenpy puzzle_10_aaaf6988:

#   "At the centre of the Mansion there is a square hole with triangular sides. Against one side there is a picture of the sun."
    "Di bagian tengah denah Mansion terdapat lubang berbentuk persegi dengan sisi-sisi berbentuk segitiga. Di salah satu sisinya terdapat gambar matahari."

#game/script.rpy:838
translate id_zenpy puzzle_10_81dd75dc:

#   "Of course! It's the sun from the pyramid! The hole is a pyramid shape!"
    "Tentu saja! Itu gambar matahari dari piramida! Lubangnya berbentuk piramida!"

#game/script.rpy:842
translate id_zenpy puzzle_10_89d33490:

#   "You take the pyramid from your bag"
    "Kamu mengambil piramida dari tasmu."

#game/script.rpy:855
translate id_zenpy puzzle_10_a9394597:

#   "You used the correct item."
    "Kamu menggunakan benda yang tepat."

#game/script.rpy:859
translate id_zenpy puzzle_10_d0cd9bc3:

#   "That's not the item needed."
    "Itu bukan benda yang dibutuhkan."

#game/script.rpy:863
translate id_zenpy puzzle_10_69baab0a:

#   "Turn it upside down and drop it in the hole making sure the sun is on the correct side."
    "Balikkan piramidanya dan masukkan ke dalam lubang, pastikan gambar mataharinya ada di sisi yang benar."

#game/script.rpy:869
translate id_zenpy puzzle_10_0a49ab94:

#   "A diagram on the base of the pyramid shows the points of the compass. Now you can tell which turret is which!"
    "Diagram di dasar piramida menunjukkan arah mata angin. Sekarang kamu bisa tahu menara mana yang mana!"

#game/script.rpy:891
translate id_zenpy waste_of_time_a2fafc6e:

#   "That's the wrong turret! If you go there you will waste too much time."
    "Itu menara yang salah! Kalau kamu pergi ke sana, kamu akan membuang banyak waktu."

#game/script.rpy:899
translate id_zenpy compass_direction_hint_104e0bc5:

#   "That's the correct turret. You write 'south-west' in your notebook. You pick up the pyramid and head back to the Grand Hall."
    "Itu menara yang benar. Kamu menulis 'barat daya' di buku catatanmu. Kamu mengambil piramida dan kembali ke Aula Besar."

#game/script.rpy:912
translate id_zenpy puzzle_11_17303d9e:

#   "After a few steps the passage splits in two. Which way should you go?"
    "Setelah beberapa langkah, lorong itu kembali bercabang dua. Kamu harus pergi ke arah mana?"

#game/script.rpy:916
translate id_zenpy puzzle_11_70131173:

#   "Then you see a message chalked on the wall…"
    "Lalu kamu melihat pesan yang ditulis dengan kapur di dinding…"

#game/script.rpy:929
translate id_zenpy puzzle_11_b211a73b:

#   "You took the correct passage! Perpendicular means 'at a right angle', or 90 degrees. The other passageway was at a 45-degree angle to your direction."
    "Kamu memilih lorong yang benar! Tegak lurus artinya membentuk sudut siku-siku, yaitu 90 derajat. Lorong lainnya membentuk sudut 45 derajat terhadap arahmu."

#game/script.rpy:942
translate id_zenpy rat_bites_f6eafacc:

#   "You turn right and keep walking. The passage goes on and on. It's getting cold and damp. You shiver."
    "Kamu belok kanan dan terus berjalan. Lorongnya semakin panjang dan tak berujung. Udara semakin dingin dan lembap. Kamu menggigil."

#game/script.rpy:946
translate id_zenpy rat_bites_0bac5a39:

#   "Suddenly there is a scurrying sound. Something runs over your foot."
    "Tiba-tiba terdengar suara berderap-derap. Ada sesuatu yang berlari di atas kakimu."

#game/script.rpy:948
translate id_zenpy rat_bites_453868c5:

#   "There are rats down here, hundreds of them! They are biting at your trouser legs!"
    "Ada tikus di sini — ratusan jumlahnya! Mereka menggigiti kaki celanamu!"

#game/script.rpy:952
translate id_zenpy rat_bites_f851d7d8:

#   "Then something big jumps among the rats - barking and yapping. They scurry away."
    "Lalu sesuatu yang besar melompat ke tengah-tengah tikus-tikus itu sambil menggonggong keras. Tikus-tikus itu pun lari tunggang-langgang."

#game/script.rpy:954
translate id_zenpy rat_bites_9230cb21:

#   "You took the wrong passage! Perpendicular means 'at a right angle', or 90 degrees. You follow the string back to the turning point."
    "Kamu mengambil lorong yang salah! Tegak lurus artinya membentuk sudut siku-siku, yaitu 90 derajat. Kamu mengikuti tali kembali ke persimpangan."

#game/script.rpy:963
translate id_zenpy puzzle_12_7399bb5c:

#   "The passage soon divides again this time in three directions."
    "Tak lama kemudian lorong itu kembali bercabang — kali ini menjadi tiga arah."

#game/script.rpy:967
translate id_zenpy puzzle_12_cfe142e3:

#   "There is another set of instructions pinned to the wall…"
    "Ada serangkaian petunjuk lain yang ditempel di dinding…"

#game/script.rpy:991
translate id_zenpy puzzle_13_bc12c04d:

#   "It's the correct direction. But soon the passageway splits again, this is giving you a headache!"
    "Itu arah yang benar. Tapi tak lama kemudian lorong itu bercabang lagi — ini bikin pusing!"

#game/script.rpy:995
translate id_zenpy puzzle_13_c9ae5143:

#   "There are more instructions taped on the wall."
    "Ada lebih banyak petunjuk yang ditempel di dinding."

#game/script.rpy:1015
translate id_zenpy puzzle_13_02b353d9:

#   "You have taken the right direction. An obtuse angle is between 90 degrees and 180 degrees. The other direction was less than 90 degrees to your tunnel, that's an acute angle."
    "Kamu memilih arah yang benar. Sudut tumpul besarnya antara 90 derajat dan 180 derajat. Arah lainnya membentuk sudut kurang dari 90 derajat — itu namanya sudut lancip."

#game/script.rpy:1023
translate id_zenpy green_eyes_creature_d3a0438f:

#   "You turn left and carry on. The light bulbs start to flicker faster and faster. Then they go out! It is completely dark!"
    "Kamu belok kiri dan terus melangkah. Lampu-lampu mulai berkedip semakin cepat. Lalu tiba-tiba padam! Gelap gulita!"

#game/script.rpy:1028
translate id_zenpy green_eyes_creature_2a75cb4d:

#   "You hear a deep growling sound ahead. Two green eyes appear from the shadows. What is it?"
    "Kamu mendengar suara geraman berat dari depan. Dua mata hijau muncul dari kegelapan. Itu apa?"

#game/script.rpy:1031
translate id_zenpy green_eyes_creature_46e6f1b6:

#   "From behind you comes a loud barking sound. The eyes back away."
    "Dari belakangmu terdengar suara gonggongan keras. Mata-mata itu pun mundur menjauh."

#game/script.rpy:1034
translate id_zenpy green_eyes_creature_cbc81732:

#   "You turn and follow your string back to the turning place. The lights come back on."
    "Kamu berbalik dan mengikuti tali kembali ke persimpangan. Lampu-lampunya menyala lagi."

#game/script.rpy:1035
translate id_zenpy green_eyes_creature_66e5720c:

#   "When you turned to the left you turned anticlockwise. You should have turned clockwise and gone to the right."
    "Saat kamu belok kiri, kamu berputar berlawanan arah jarum jam. Seharusnya kamu berputar searah jarum jam dan belok ke kanan."

#game/script.rpy:1042
translate id_zenpy minotaur_adfbe5f3:

#   "You turn to the right by less than a right angle, but suddenly come to a dead-end."
    "Kamu belok ke kanan kurang dari satu sudut siku-siku, tapi tiba-tiba kamu sampai di jalan buntu."

#game/script.rpy:1046
translate id_zenpy minotaur_8d17a99d:

#   "You turn around. A dog with huge jaws and glowing green eyes blocks your path. It's Minotaur, the bull-mastifl!"
    "Kamu berbalik. Seekor anjing dengan rahang besar dan mata hijau bersinar menghalangi jalanmu. Itu Minotaur, si anjing banteng!"

#game/script.rpy:1049
translate id_zenpy minotaur_2727c49f:

#   "Then you hear growling from behind you. Minotaur looks nervous. The growling gets louder until Minotaur runs away."
    "Lalu kamu mendengar suara geraman dari belakangmu. Minotaur terlihat gelisah. Geramannya semakin keras sampai akhirnya Minotaur kabur."

#game/script.rpy:1052
translate id_zenpy minotaur_09df18ba:

#   "You chose the wrong direction."
    "Kamu memilih arah yang salah."

#game/script.rpy:1053
translate id_zenpy minotaur_c53eb49b:

#   "An obtuse angle is between 90 degrees and 180 degrees. You turned less than 90 degrees, that's an acute angle."
    "Sudut tumpul besarnya antara 90 derajat dan 180 derajat. Kamu berbelok kurang dari 90 derajat — itu namanya sudut lancip."

#game/script.rpy:1054
translate id_zenpy minotaur_481910e6:

#   "You follow the string back to the turning point."
    "Kamu mengikuti tali kembali ke persimpangan."

#game/script.rpy:1063
translate id_zenpy puzzle_14_91d1114b:

#   "The passageway ends at a door labelled 'Candle Store'."
    "Lorong itu berakhir di sebuah pintu berlabel 'Gudang Lilin'."

#game/script.rpy:1066
translate id_zenpy puzzle_14_bb1599bb:

#   "You turn the handle and enter. The storeroom is packed with candles on shelves."
    "Kamu memutar gagangnya dan masuk. Gudang itu penuh sesak dengan berbagai lilin di rak-raknya."

#game/script.rpy:1068
translate id_zenpy puzzle_14_a978a1f7:

#   "You remember the note at the top of the cellar stairs said, You will need a shape with no flat faces and no edges to light your way.' It could be a candle!"
    "Kamu ingat catatan di atas tangga gudang tadi: 'Kamu akan butuh bentuk yang tidak punya bidang datar dan rusuk untuk menerangi jalanmu.' Mungkin itu lilin!"

#game/script.rpy:1076
translate id_zenpy puzzle_14_b283b7bb:

#   "You take a spherical candle from the shelf. You step back through the door."
    "Kamu mengambil lilin berbentuk bola dari rak. Kamu melangkah mundur melewati pintu."

#game/script.rpy:1079
translate id_zenpy puzzle_14_d0d73ee7:

#   "Suddenly all the lights in the passage fail! But a flame appears on your candle. It lights your way - just as the letter said it would!"
    "Tiba-tiba semua lampu di lorong itu padam! Tapi nyala api muncul di lilinmu. Lilin itu menerangi jalanmu — persis seperti yang tertulis di surat!"

#game/script.rpy:1080
translate id_zenpy puzzle_14_37cb0d7f:

#   "You were right. A sphere has no flat surfaces or edges. Its surface is a smooth curve all over."
    "Kamu benar. Bola tidak memiliki permukaan datar atau rusuk sama sekali. Permukaannya berbentuk lengkungan mulus di seluruh bagiannya."

#game/script.rpy:1097
translate id_zenpy puzzle_15_4637b4ef:

#   "As you leave the Candle Store you see another note pinned to the door. You study the directions on the note…"
    "Saat kamu keluar dari Gudang Lilin, kamu melihat catatan lain yang ditempel di pintu. Kamu mempelajari petunjuk di catatan itu…"

#game/script.rpy:1101
translate id_zenpy puzzle_15_1cade1c3:

#   "You leave the Candle Store, turning left out of the door."
    "Kamu meninggalkan Gudang Lilin dan belok kiri begitu keluar dari pintu."

#game/script.rpy:1106
translate id_zenpy puzzle_15_5b7e76f5:

#   "Soon you come to a space with passages leading in four directions, just as the note said you would."
    "Tak lama kemudian kamu tiba di sebuah ruang terbuka dengan lorong yang mengarah ke empat arah, persis seperti yang dikatakan dalam catatan itu."

#game/script.rpy:1107
translate id_zenpy puzzle_15_ebd501a7:

#   "Which one is parallel to the passage along which you came?"
    "Manakah lorong yang sejajar dengan lorong yang baru saja kamu lalui?"

#game/script.rpy:1122
translate id_zenpy puzzle_15_9ca3a479:

#   "You have chosen the correct direction! You walk along the passage."
    "Kamu memilih arah yang benar! Kamu berjalan menyusuri lorong."

#game/script.rpy:1125
translate id_zenpy puzzle_15_03770155:

#   "The air gets warmer. You hear the hiss of steam and the roar of flames. You must be heading for the boiler room. That's where the letter told you to go!"
    "Udara semakin hangat. Kamu mendengar desis uap dan gemuruh api. Kamu pasti sedang menuju ruang ketel. Ke sanalah surat itu menyuruhmu pergi!"

#game/script.rpy:1133
translate id_zenpy heated_room_ec3dbc21:

#   "You lift down a cylindrical candle from the shelf. Its wick bursts into flame. The other candles start to light, too."
    "Kamu mengambil lilin berbentuk silinder dari rak. Sumbunya langsung menyala. Lilin-lilin lainnya pun ikut menyala."

#game/script.rpy:1134
translate id_zenpy heated_room_9c3bac46:

#   "The small room gets hotter and hotter! The candles start to melt the flames start to spread!"
    "Ruangan kecil itu semakin panas! Lilin-lilin mulai meleleh dan api mulai menyebar ke mana-mana!"

#game/script.rpy:1136
translate id_zenpy heated_room_c146da6f:

#   "You spot a bucket of sand in the corner. You spread the sand to smother the flames that was close!"
    "Kamu melihat ember berisi pasir di sudut ruangan. Kamu menebarkan pasir untuk memadamkan api — hampir saja celaka!"

#game/script.rpy:1139
translate id_zenpy heated_room_e3737231:

#   "You chose the wrong candle. A cylinder has two flat surfaces in the shape of circles one at either end."
    "Kamu memilih lilin yang salah. Silinder memiliki dua permukaan datar berbentuk lingkaran, satu di setiap ujungnya."

#game/script.rpy:1146
translate id_zenpy freezer_room_b46ab47d:

#   "You set off along passage 2. It gets colder the further you go. There is a door at the end marked 'Ice Store'."
    "Kamu berjalan menyusuri lorong 2. Semakin jauh, semakin dingin rasanya. Di ujung lorong ada pintu bertanda 'Gudang Es'."

#game/script.rpy:1150
translate id_zenpy freezer_room_5ab57f45:

#   "You open it and look inside. The walls and ceiling are covered in frost."
    "Kamu membukanya dan mengintip ke dalam. Dinding dan langit-langitnya tertutup lapisan es."

#game/script.rpy:1154
translate id_zenpy freezer_room_fe450531:

#   "Then the door slams behind you. You hear the key turn in the lock! You are trapped! You will freeze!"
    "Lalu pintu itu terbanting di belakangmu. Kamu mendengar kunci diputar di gembok! Kamu terjebak! Kamu akan membeku!"

#game/script.rpy:1157
translate id_zenpy freezer_room_7ee65814:

#   "Then you hear paws scrabbling at the door."
    "Lalu kamu mendengar suara cakar yang menggaruk-garuk pintu."

#game/script.rpy:1160
translate id_zenpy freezer_room_57317cc7:

#   "The key drops to the floor with a clang. It is pushed under the door so you can escape!"
    "Kunci itu jatuh ke lantai dengan bunyi dentang. Lalu kunci itu digeser masuk ke bawah pintu agar kamu bisa kabur!"

#game/script.rpy:1163
translate id_zenpy freezer_room_b8714a81:

#   "You chose the wrong direction. When two directions are parallel they are the same distance apart at every point and never meet."
    "Kamu memilih arah yang salah. Dua garis yang sejajar memiliki jarak yang sama di setiap titik dan tidak pernah bertemu."

#game/script.rpy:1164
translate id_zenpy freezer_room_5ce0947e:

#   "You follow your string back along the passageway."
    "Kamu mengikuti tali kembali sepanjang lorong."

#game/script.rpy:1174
translate id_zenpy puzzle_16_a6c399c0:

#   "The boiler room door is open. It's very hot inside. The fire is blazing inside the furnace. Hot steam pipes rattle and hiss."
    "Pintu ruang ketel terbuka. Di dalam terasa sangat panas. Api berkobar di dalam tungku. Pipa-pipa uap panas berderak dan mendesis."

#game/script.rpy:1175
translate id_zenpy puzzle_16_14bd4198:

#   "The pressure gauge shows danger when the boiler is about to explode!"
    "Pengukur tekanan menunjukkan tanda bahaya — ketelnya hampir meledak!"

#game/script.rpy:1179
translate id_zenpy puzzle_16_aed3c555:

#   "You see a notice on the boiler wall…"
    "Kamu melihat sebuah pengumuman di dinding ketel…"

#game/script.rpy:1189
translate id_zenpy puzzle_16_03d308db:

#   "You've made half a turn. That's only 180 degrees! The pipes start to shake and squeal!"
    "Kamu baru memutar setengah putaran. Itu baru 180 derajat! Pipa-pipa mulai bergetar dan berdecit!"

#game/script.rpy:1190
translate id_zenpy puzzle_16_dd5cbec3:

#   "You realize your mistake. You turn the wheel another half turn. That makes 360 degrees altogether. The pressure starts to fall."
    "Kamu sadar akan kesalahanmu. Kamu memutar roda setengah putaran lagi. Jadi totalnya 360 derajat. Tekanan pun mulai turun."

#game/script.rpy:1196
translate id_zenpy puzzle_16_0200e6a5:

#   "You have turned the wheel a whole turn. That's correct. One whole turn is 360 degrees. The pressure starts to fall and the boiler settles down."
    "Kamu telah memutar roda satu putaran penuh. Itu benar! Satu putaran penuh sama dengan 360 derajat. Tekanan mulai turun dan ketel pun tenang kembali."

#game/script.rpy:1204
translate id_zenpy puzzle_17_a8549537:

#   "You look around the rest of the boiler room, In one corner you see a stack of thin parcels wrapped with brown paper."
    "Kamu melihat sekeliling sisa ruang ketel. Di salah satu sudut kamu melihat tumpukan bungkusan tipis yang dibungkus kertas coklat."

#game/script.rpy:1208
translate id_zenpy puzzle_17_f2ea9b35:

#   "Are they the stolen paintings? You look closely at the parcels, You recognize some of the shapes, but there are too many!"
    "Apakah itu lukisan yang dicuri? Kamu memperhatikan bungkusan-bungkusan itu dengan cermat. Kamu mengenali beberapa bentuknya, tapi jumlahnya terlalu banyak!"

#game/script.rpy:1214
translate id_zenpy puzzle_17_be09487a:

#   "Then you find a note on one of the parcels…"
    "Lalu kamu menemukan sebuah catatan di salah satu bungkusan…"

#game/script.rpy:1218
translate id_zenpy puzzle_17_6b7d2ba0:

#   "You look back at your notebook for the shapes of the paintings."
    "Kamu membuka kembali buku catatanmu untuk melihat bentuk-bentuk lukisan yang dicuri."

#game/script.rpy:1221
translate id_zenpy puzzle_17_3afb7326:

#   "You've written 'square, rectangle, hexagon, octagon'."
    "Kamu telah mencatat 'persegi, persegi panjang, segi enam, segi delapan'."

#game/script.rpy:1238
translate id_zenpy loud_bark_noise_59515856:

#   "A loud barking noise warns you that something is wrong. You have not picked up all the real paintings! Quickly you replace the fake paintings."
    "Gonggongan keras memperingatkanmu bahwa ada yang tidak beres. Kamu belum mengambil semua lukisan aslinya! Dengan cepat kamu mengembalikan lukisan palsu itu."

#game/script.rpy:1241
translate id_zenpy loud_bark_noise_1e2deebe:

#   "This shape is a trapezium, not a hexagon. A hexagon has six sides."
    "Bentuk ini adalah trapesium, bukan segi enam. Segi enam memiliki enam sisi."

#game/script.rpy:1245
translate id_zenpy loud_bark_noise_1c3679d0:

#   "This shape is a pentagon, not an octagon. An octagon has eight sides."
    "Bentuk ini adalah segi lima, bukan segi delapan. Segi delapan memiliki delapan sisi."

#game/script.rpy:1255
translate id_zenpy silver_button_hint_84923092:

#   "You have taken the correct paintings! You run from the boiler room with them in your arms."
    "Kamu mengambil lukisan yang benar! Kamu berlari keluar dari ruang ketel sambil menggendong lukisan-lukisan itu."

#game/script.rpy:1263
translate id_zenpy silver_button_hint_a59b69e7:

#   "You hear heavy footsteps coming down the passageway."
    "Kamu mendengar langkah kaki yang berat mendekat dari lorong."

#game/script.rpy:1266
translate id_zenpy silver_button_hint_1ff246be:

#   "Which way should you go? Then you hear a scraping sound. A hidden door is opening in the wall!"
    "Ke mana kamu harus pergi? Lalu kamu mendengar suara gesekan. Ada pintu tersembunyi yang terbuka di dinding!"

#game/script.rpy:1267
translate id_zenpy silver_button_hint_960b0798:

#   "You feel afraid and turn to run, but strong teeth grab you from behind. They pull you through the door."
    "Kamu merasa takut dan hendak berlari, tapi gigi yang kuat mencengkerammu dari belakang. Kamu ditarik masuk melewati pintu itu."

#game/script.rpy:1272
translate id_zenpy silver_button_hint_f8e9e7e5:

#   "You are in a small room filled with precious china, silver plates and candlesticks."
    "Kamu berada di sebuah ruangan kecil yang penuh dengan porselen berharga, piring-piring perak, dan tempat lilin."

#game/script.rpy:1273
translate id_zenpy silver_button_hint_474c1b61:

#   "This is where the Mansion's valuables are kept! It's a great place to hide the paintings."
    "Di sinilah barang-barang berharga Mansion disimpan! Tempat ini sempurna untuk menyembunyikan lukisan-lukisan itu."

#game/script.rpy:1276
translate id_zenpy silver_button_hint_6b11e30a:

#   "Then you hear an angry shout. The burglar has discovered the paintings are gone!"
    "Lalu kamu mendengar teriakan marah. Pencuri itu menemukan bahwa lukisan-lukisannya sudah tidak ada!"

#game/script.rpy:1279
translate id_zenpy silver_button_hint_52d4d459:

#   "He or she runs back the way they came. You hear footsteps disappearing into the distance."
    "Si pencuri berlari kembali ke arah yang tadi dilaluinya. Kamu mendengar suara langkah kaki yang semakin menjauh."

#game/script.rpy:1281
translate id_zenpy silver_button_hint_18e9535a:

#   "You have saved the paintings! But there is still much to do. There are burglars to catch!"
    "Kamu telah menyelamatkan lukisan-lukisannya! Tapi masih banyak yang harus dilakukan. Para pencuri itu harus ditangkap!"

#game/script.rpy:1286
translate id_zenpy silver_button_hint_9094e7a9:

#   "The secret door opens again as you push it. You begin to follow the string to find your way back."
    "Pintu rahasia itu terbuka lagi saat kamu mendorongnya. Kamu mulai mengikuti tali untuk menemukan jalan kembali."

#game/script.rpy:1290
translate id_zenpy silver_button_hint_358e84c0:

#   "As you pass the boiler room you see something shining on the floor."
    "Saat kamu melewati ruang ketel, kamu melihat sesuatu yang berkilap di lantai."

#game/script.rpy:1291
translate id_zenpy silver_button_hint_5800afcb:

#   "It's a silver button. It could be another clue! You pop it in your pocket, and follow the string all the way back to the entrance hall."
    "Sebuah kancing perak. Ini bisa jadi petunjuk lain! Kamu memasukkannya ke dalam saku dan mengikuti tali kembali ke aula depan."

#game/script.rpy:1308
translate id_zenpy puzzle_18_19646877:

#   "You look around. Then you see a set of kitchen scales on a table. Next to it is a bag of flour, and a floury hand print on the table top."
    "Kamu melihat sekeliling. Lalu kamu melihat timbangan dapur di atas meja. Di sebelahnya ada sekantong tepung, dan bekas telapak tangan yang bertepung di permukaan meja."

#game/script.rpy:1312
translate id_zenpy puzzle_18_9b7ae3f1:

#   "The hand that made the print has a scar! You sketch the print in your notebook."
    "Tangan yang membuat bekas itu memiliki bekas luka! Kamu membuat sketsa bekas tangan itu di buku catatanmu."

#game/script.rpy:1319
translate id_zenpy puzzle_18_ae220b25:

#   "Someone has left a list of instructions on a scrap of paper next to the flour. You decide to follow the instructions to work out what they were doing!"
    "Seseorang meninggalkan daftar instruksi pada secarik kertas di sebelah tepung. Kamu memutuskan untuk mengikuti instruksi itu untuk mencari tahu apa yang sedang mereka lakukan!"

#game/script.rpy:1329
translate id_zenpy puzzle_18_db0d6bcd:

#   "You chose the correct weights! You add the flour until the scales are level."
    "Kamu memilih pemberat yang tepat! Kamu menuangkan tepung sampai timbangan seimbang."

#game/script.rpy:1343
translate id_zenpy puzzle_19_d14cbe9f:

#   "You read the next instruction…"
    "Kamu membaca instruksi berikutnya…"

#game/script.rpy:1347
translate id_zenpy puzzle_19_25de5b28:

#   "There is a row of bowls of all different sizes - high on a shelf."
    "Ada deretan mangkuk berbagai ukuran — di rak yang letaknya tinggi."

#game/script.rpy:1348
translate id_zenpy puzzle_19_cd58aeb7:

#   "But which is the 15 cm radius bow!? Then you remember your school ruler is 30 cm long."
    "Tapi yang manakah mangkuk berdiameter 15 cm itu? Lalu kamu teringat bahwa penggaris sekolahmu panjangnya 30 cm."

#game/script.rpy:1352
translate id_zenpy puzzle_19_0aeab3aa:

#   "You try to imagine your ruler next to each of the bowls."
    "Kamu mencoba membayangkan penggaris itu diletakkan di samping masing-masing mangkuk."

#game/script.rpy:1362
translate id_zenpy puzzle_19_fcfebc79:

#   "You have chosen the correct bowl. Its diameter is 30 cm. so its radius is 15 cm."
    "Kamu memilih mangkuk yang benar. Diameternya 30 cm, jadi jari-jarinya adalah 15 cm."

#game/script.rpy:1365
translate id_zenpy puzzle_19_d14cbe9f_1:

#   "You read the next instruction…"
    "Kamu membaca instruksi berikutnya…"

#game/script.rpy:1380
translate id_zenpy scale_trap_0af224f9:

#   "You start pouring the flour. The scales tilt with a jerk. Someone has tied a string to one pan. It's a trap!"
    "Kamu mulai menuangkan tepung. Timbangan miring tiba-tiba dengan sentakan keras. Seseorang telah mengikat tali di salah satu wadah timbangan. Ini jebakan!"

#game/script.rpy:1385
translate id_zenpy scale_trap_ed91b1c8:

#   "The string pulls a jar of oil from a shelf onto an oven. The jar shatters. The oil catches fire! You must not put water on an oil fire because it will spread!"
    "Tali itu menarik toples minyak dari rak dan jatuh ke atas oven. Toplesnya pecah. Minyaknya terbakar! Jangan siram api minyak dengan air karena justru akan semakin menyebar!"

#game/script.rpy:1388
translate id_zenpy scale_trap_b3e9fabb:

#   "Then a bark makes you turn. You see a fire blanket next to the ovens. You grab it and spread it over the flames. The flames go out."
    "Lalu gonggongan membuat kamu menoleh. Kamu melihat selimut pemadam api di sebelah oven. Kamu meraihnya dan menutupkan ke atas api. Nyala api pun padam."

#game/script.rpy:1391
translate id_zenpy scale_trap_afc395f9:

#   "There are 1000 g in a kg, so 0.5 kg is 500 g not 50 g."
    "Ada 1000 g dalam 1 kg, jadi 0,5 kg sama dengan 500 g, bukan 50 g."

#game/script.rpy:1402
translate id_zenpy puzzle_20_9041e5e3:

#   "You look around for some salt. You see three shakers on a shelf. There is a note next to them…"
    "Kamu mencari-cari garam. Kamu melihat tiga wadah bumbu di rak. Ada sebuah catatan di sebelahnya…"

#game/script.rpy:1408
translate id_zenpy puzzle_20_4ce969b8:

#   "You decide to see how the shapes roll."
    "Kamu memutuskan untuk melihat bagaimana bentuk-bentuk itu menggelinding."

#game/script.rpy:1409
translate id_zenpy puzzle_20_82aa3408:

#   "You try the cuboid first. You lay it on its side but it will not roll at all."
    "Kamu mencoba balok terlebih dahulu. Kamu memiringkannya tapi ia sama sekali tidak menggelinding."

#game/script.rpy:1410
translate id_zenpy puzzle_20_e82aab36:

#   "Then you try the cylinder and the cone. One of them rolls in a straight line away from you. The other rolls around in a circle and comes back!"
    "Lalu kamu mencoba silinder dan kerucut. Salah satunya menggelinding lurus menjauhi kamu. Yang satunya berputar melingkar dan kembali ke arahmu!"

#game/script.rpy:1425
translate id_zenpy puzzle_20_e28fc7f7:

#   "You shake the cone over the flour bowl. It's the right shaker. A sprinkle of salt falls onto the flour."
    "Kamu mengocok wadah berbentuk kerucut di atas mangkuk tepung. Itu wadah yang tepat. Taburan garam pun jatuh ke atas tepung."

#game/script.rpy:1426
translate id_zenpy puzzle_20_3f59db8f:

#   "A cone rolls in a circle when you lay it on its side."
    "Kerucut akan menggelinding membentuk lingkaran ketika dimiringkan pada sisinya."

#game/script.rpy:1427
translate id_zenpy puzzle_20_1c915c75:

#   "On the shelf next to the shakers you see a jar labelled 'yeast', You add a spoonful of that to your mixture, too."
    "Di rak di sebelah wadah bumbu, kamu melihat toples berlabel 'ragi'. Kamu juga menambahkan sesendok ragi ke dalam adonanmu."

#game/script.rpy:1433
translate id_zenpy poisonous_spider_81abf1c6:

#   "As you lift the bowl from the shelf you look inside. A row of shiny white eyes stares back!"
    "Saat kamu mengangkat mangkuk dari rak, kamu mengintip ke dalamnya. Sederet mata putih berkilat menatapmu balik!"

#game/script.rpy:1439
translate id_zenpy poisonous_spider_d5d099f5:

#   "It's a huge poisonous spider! A loud bark makes you drop the bowl. It shatters. The spider scuttles behind the sinks."
    "Laba-laba beracun yang sangat besar! Gonggongan keras membuat kamu menjatuhkan mangkuknya. Mangkuk itu pecah. Laba-labanya berlari bersembunyi di balik bak cuci."

#game/script.rpy:1443
translate id_zenpy poisonous_spider_84d7de2d:

#   "You chose the wrong bowl! The radius of a circle is half its diameter. Bowl Y has a diameter of 15 cm, so its radius is 7.5 cm."
    "Kamu memilih mangkuk yang salah! Jari-jari lingkaran adalah setengah dari diameternya. Mangkuk Y berdiameter 15 cm, jadi jari-jarinya adalah 7,5 cm."

#game/script.rpy:1454
translate id_zenpy strong_pepper_338354f7:

#   "You shake the cylinder over the flour bowl. It's pepper, not salt."
    "Kamu mengocok wadah silinder di atas mangkuk tepung. Ternyata isi wadah itu merica, bukan garam."

#game/script.rpy:1455
translate id_zenpy strong_pepper_170d722b:

#   "But this is not ordinary pepper, it is extra strong! Your eyes are watering, your nose running and your mouth burning. You think your head will explode!"
    "Tapi ini bukan merica biasa — ini merica super pedas! Matamu berair, hidungmu meler, dan mulutmu terasa terbakar. Rasanya kepalamu mau meledak!"

#game/script.rpy:1458
translate id_zenpy strong_pepper_a53eaed8:

#   "Then something pushes you to the sinks you need to wash the pepper away. You hold your head under a running tap until you feel better."
    "Lalu sesuatu mendorongmu ke arah bak cuci — kamu perlu membasuh merica itu. Kamu menundukkan kepalamu di bawah keran yang mengalir sampai terasa lebih baik."

#game/script.rpy:1459
translate id_zenpy strong_pepper_551c4409:

#   "A cylinder rolls in a straight line when you lay it on its side."
    "Silinder akan menggelinding dalam garis lurus ketika dimiringkan pada sisinya."

#game/script.rpy:1468
translate id_zenpy puzzle_21_e706a972:

#   "Now you need some water. There are plenty of taps over the sinks, but how will you measure 250 ml? You see a measuring jug. That's what you need!"
    "Sekarang kamu membutuhkan air. Ada banyak keran di atas bak cuci, tapi bagaimana caranya mengukur 250 ml? Kamu melihat gelas ukur. Nah, itulah yang kamu butuhkan!"

#game/script.rpy:1471
translate id_zenpy puzzle_21_cfd2677f:

#   "The jug has a scale. It is marked 1 litre at the top, but the only other markings are fractions."
    "Gelas ukur itu memiliki skala. Tandanya 1 liter di bagian paling atas, tapi tanda-tanda lainnya hanya berupa pecahan."

#game/script.rpy:1472
translate id_zenpy puzzle_21_e6b6438b:

#   "Luckily you think you know how many millilitres there are in a litre. So you fill the jug to the correct level."
    "Untungnya kamu tahu berapa mililiter yang ada dalam satu liter. Jadi kamu mengisi gelas ukur hingga tanda yang tepat."

#game/script.rpy:1486
translate id_zenpy puzzle_21_657519b7:

#   "You have measured correctly! As you stir in the water, the mixture becomes soft and rubbery. It's bread dough! That must be the clue."
    "Kamu mengukur dengan benar! Saat kamu mengaduk air ke dalam campuran, adonannya menjadi lembut dan kenyal. Ini adonan roti! Pasti itulah petunjuknya."

#game/script.rpy:1487
translate id_zenpy puzzle_21_daf9fe18:

#   "You remember smelling baking bread. Someone had been baking just before you arrived. It must have been the burglars, but why would they bake bread in the middle of a robbery?"
    "Kamu ingat mencium aroma roti yang dipanggang tadi. Seseorang baru saja memanggang roti sebelum kamu tiba. Pasti itu pencurinya — tapi kenapa mereka memanggang roti di tengah perampokan?"

#game/script.rpy:1494
translate id_zenpy ivy_trap_b6f93e33:

#   "That's too much water! As you lift the jug, its handle snaps. It had been partly cut through! The jug shatters. The water seeps between the flagstones on the kitchen floor."
    "Terlalu banyak air! Saat kamu mengangkat gelas ukur, pegangannya patah. Ternyata sudah dipotong sebagian! Gelas ukurnya pecah. Air merembes di antara batu lantai dapur."

#game/script.rpy:1498
translate id_zenpy ivy_trap_da929ff4:

#   "Ivy starts to grow from the cracks. It wraps around your ankles you are trapped!"
    "Tanaman rambat mulai tumbuh dari celah-celah lantai. Ranggasannya melilit pergelangan kakimu — kamu terjebak!"

#game/script.rpy:1500
translate id_zenpy ivy_trap_bbfcff82:

#   "Then you feel strong jaws grab your belt and pull."
    "Lalu kamu merasakan rahang yang kuat mencengkeram ikat pinggangmu dan menarik."

#game/script.rpy:1501
translate id_zenpy ivy_trap_0aba887e:

#   "You break free from the tendrils. Quickly, you sprinkle salt on the ivy leaves, and they shrink back."
    "Kamu berhasil melepaskan diri dari sulur-sulur itu. Dengan cepat, kamu menaburkan garam pada daun-daun tanaman itu, dan mereka pun mengkerut kembali."

#game/script.rpy:1502
translate id_zenpy ivy_trap_f5fc5cad:

#   "There are 1000 ml in a litre. So 250 ml is less than ½ litre. What fraction of 1000 is 250?"
    "Ada 1000 ml dalam 1 liter. Jadi 250 ml itu kurang dari ½ liter. Berapa pecahan dari 1000 yang sama dengan 250?"

#game/script.rpy:1511
translate id_zenpy bite_footprint_hint_62b41480:

#   "You look around for the newly baked bread. The smell leads you into the larder where there is a pile of fresh loaves."
    "Kamu mencari-cari roti yang baru dipanggang. Aromanya membawamu ke ruang simpan makanan di mana ada tumpukan roti-roti segar."

#game/script.rpy:1515
translate id_zenpy bite_footprint_hint_fa36f6d4:

#   "One of the loaves has a bite mark in it. The burglar could not resist eating the warm bread!"
    "Salah satu rotinya ada bekas gigitan. Si pencuri tidak tahan untuk tidak memakan roti yang masih hangat itu!"

#game/script.rpy:1516
translate id_zenpy bite_footprint_hint_2fe6cef6:

#   "Then you notice something odd. There is a gap in the teeth marks, It's another clue! This burglar has a missing tooth! You take the piece with the teeth marks to use as evidence."
    "Lalu kamu melihat sesuatu yang aneh. Ada celah di antara bekas gigi itu — itu petunjuk lain! Pencuri ini giginya ompong! Kamu mengambil potongan roti dengan bekas gigitan itu sebagai bukti."

#game/script.rpy:1517
translate id_zenpy bite_footprint_hint_20edd120:

#   "As you pick up the loaf it feels too heavy for bread. You break the loaf open."
    "Saat kamu mengambil roti itu, rasanya terlalu berat untuk sebuah roti. Kamu membelah rotinya."

#game/script.rpy:1523
translate id_zenpy bite_footprint_hint_3a422442:

#   "There is a necklace inside! You feel the other loaves. They are heavy, too. That's how the burglars have hidden the jewels!"
    "Ada kalung di dalamnya! Kamu meraba roti-roti lainnya. Semuanya juga berat. Begitu cara para pencuri menyembunyikan perhiasannya!"

#game/script.rpy:1531
translate id_zenpy bite_footprint_hint_b0ba48f9:

#   "Then you hear footsteps in the corridor. One of the burglars is coming back. Quickly you hide the broken bread under the other loaves."
    "Lalu kamu mendengar langkah kaki di koridor. Salah satu pencuri sedang kembali ke sini. Dengan cepat kamu menyembunyikan potongan roti itu di bawah roti-roti lainnya."

#game/script.rpy:1533
translate id_zenpy bite_footprint_hint_7af5d80c:

#   "You spot a cupboard where you can hide, but before you get inside, you sprinkle flour on the floor"
    "Kamu melihat lemari tempat kamu bisa bersembunyi, tapi sebelum masuk ke dalamnya, kamu menaburkan tepung di lantai terlebih dahulu."

#game/script.rpy:1534
translate id_zenpy bite_footprint_hint_fef5af5a:

#   "From inside the cupboard you hear the burglar's footsteps. Luckily he or she doesn't spot the broken loaf. You keep still until the footsteps retreat."
    "Dari dalam lemari kamu mendengar langkah kaki si pencuri. Untungnya dia tidak melihat roti yang sudah dibelah itu. Kamu diam tak bergerak sampai langkah kaki itu menjauh."

#game/script.rpy:1538
translate id_zenpy bite_footprint_hint_f7df2f91:

#   "As you climb out from the cupboard you look at the floor. The burglar has left clear footprints in the flour. You take out your notebook and make a careful sketch..."
    "Saat kamu keluar dari lemari, kamu melihat ke lantai. Si pencuri telah meninggalkan jejak kaki yang jelas di tepung. Kamu mengeluarkan buku catatan dan membuat sketsa dengan teliti..."

#game/script.rpy:1545
translate id_zenpy bite_footprint_hint_51dc83b5:

#   "There are some paw prints as well!"
    "Ada juga beberapa jejak cakar di sana!"

#game/script.rpy:1552
translate id_zenpy bite_footprint_hint_d2366896:

#   "Now you have located the jewels in the kitchen, and found the teeth marks in the bread, you must look for clues in other parts of the Mansion."
    "Sekarang kamu sudah menemukan perhiasan di dapur dan bekas gigitan di roti. Kamu harus mencari petunjuk di bagian lain Mansion."

#game/script.rpy:1553
translate id_zenpy bite_footprint_hint_4871de10:

#   "You head back to the Grand Hall as fast as you can!"
    "Kamu kembali ke Aula Besar secepat mungkin!"

#game/script.rpy:1567
translate id_zenpy scribbled_note_28d29a8e:

#   "You run up the stairs. On the top step you find a scribbled note…"
    "Kamu berlari menaiki tangga. Di anak tangga paling atas kamu menemukan sebuah catatan coretan…"

#game/script.rpy:1580
translate id_zenpy scribbled_note_0402f73b:

#   "You haven't found all the lost items yet."
    "Kamu belum menemukan semua barang yang hilang."

#game/script.rpy:1589
translate id_zenpy scribbled_note_83a18961:

#   "You have found all the lost items."
    "Kamu sudah menemukan semua barang yang hilang."

#game/script.rpy:1599
translate id_zenpy puzzle_22_ffd8fca8:

#   "Suddenly you realize a large friendly dog is bounding up the stairs with you."
    "Tiba-tiba kamu menyadari seekor anjing besar yang ramah sedang berlari-lari menaiki tangga bersamamu."

#game/script.rpy:1600
translate id_zenpy puzzle_22_dc45d985:

#   "It's Barkimedes the bloodhound. The Mansion is his home, and he's been helping you all along!"
    "Itu Barkimedes si anjing pelacak. Mansion adalah rumahnya, dan ia ternyata sudah membantumu sejak tadi!"

#game/script.rpy:1604
translate id_zenpy puzzle_22_ff8658e2:

#   "On the first-floor landing there are rows of doors. All are closed apart from one. You step inside."
    "Di lantai pertama ada deretan pintu-pintu. Semuanya tertutup, kecuali satu. Kamu melangkah masuk."

#game/script.rpy:1610
translate id_zenpy puzzle_22_ffe3d54b:

#   "It's the owner's bedroom! The burglars have been in and stolen some of his clothes! Why would they do that? In their hurry they seem to have knocked the clock from the table."
    "Ini kamar tidur pemilik Mansion! Para pencuri telah masuk dan mencuri beberapa pakaiannya! Mengapa mereka melakukan itu? Terburu-buru, mereka sepertinya menjatuhkan jam dari meja."

#game/script.rpy:1635
translate id_zenpy wrong_time_8be2d33f:

#   "That's the wrong time! The big hand shows the minutes and the little hand the hours."
    "Itu waktu yang salah! Jarum panjang menunjukkan menit dan jarum pendek menunjukkan jam."

#game/script.rpy:1636
translate id_zenpy wrong_time_01d7ec54:

#   "The little hand is on the nine. The big hand is pointing at three a quarter of the way around the clock face."
    "Jarum pendek ada di angka sembilan. Jarum panjang menunjuk ke arah angka tiga — seperempat putaran dari atas."

#game/script.rpy:1637
translate id_zenpy wrong_time_9f97ef2f:

#   "It is a quarter past nine. We could also call this nine fifteen (9:15) because there are 60 minutes in an hour and so a quarter of an hour is 15 minutes."
    "Ini menunjukkan pukul sembilan lewat seperempat. Kita juga bisa menyebutnya pukul 9.15 karena satu jam ada 60 menit, jadi seperempat jam sama dengan 15 menit."

#game/script.rpy:1645
translate id_zenpy puzzle_23_0d6e950c:

#   "That's the correct time! The clock was stopped at a quarter past nine."
    "Itu waktu yang benar! Jam itu berhenti pada pukul sembilan lewat seperempat."

#game/script.rpy:1649
translate id_zenpy puzzle_23_25a88c3a:

#   "Then you see a note on the mantelpiece. You read it carefully…"
    "Lalu kamu melihat sebuah catatan di rak perapian. Kamu membacanya dengan seksama…"

#game/script.rpy:1655
translate id_zenpy puzzle_23_0828720d:

#   "You look at your watch to see the time now…"
    "Kamu melihat jam tanganmu untuk mengecek waktu sekarang…"

#game/script.rpy:1666
translate id_zenpy puzzle_23_8866aa80:

#   "That's correct! As you move the hands to the correct time, it starts to tick."
    "Benar! Saat kamu menggerakkan jarum jam ke waktu yang tepat, jam itu mulai berdetak."

#game/script.rpy:1683
translate id_zenpy puzzle_24_9a52d81f:

#   "You look around the bedroom for more clues. You see a door next to the bed. The door is open a crack and you see the light is on."
    "Kamu mencari petunjuk lain di kamar tidur. Kamu melihat sebuah pintu di samping tempat tidur. Pintunya terbuka sedikit dan kamu bisa melihat lampu menyala di dalamnya."

#game/script.rpy:1689
translate id_zenpy puzzle_24_7f4f532c:

#   "You open the door slowly and find yourself in a small bathroom. The basin is a mess. Someone has been using hair dye and hair clippers!"
    "Kamu membuka pintu perlahan dan menemukan dirimu di sebuah kamar mandi kecil. Bak cucinya berantakan. Seseorang baru saja menggunakan pewarna rambut dan alat cukur!"

#game/script.rpy:1691
translate id_zenpy puzzle_24_7ca818d7:

#   "Then you see someone has been playing noughts and crosses in the steam on the bathroom mirror. There is a message underneath..."
    "Lalu kamu melihat seseorang telah menggambar permainan lingkaran dan silang di cermin kamar mandi yang berembun. Ada pesan di bawahnya..."

#game/script.rpy:1701
translate id_zenpy puzzle_24_063e4191:

#   "A cross is correct! The pattern looks the same if you turn it by 90 degrees or 180 degrees, or look at it in a mirror."
    "Tanda silang adalah jawabannya! Polanya terlihat sama jika diputar 90 derajat atau 180 derajat, atau dilihat di cermin."

#game/script.rpy:1706
translate id_zenpy puzzle_24_9aa6f614:

#   "As you add the cross, steam starts to clear from the mirror. Another message is revealed…"
    "Saat kamu menambahkan tanda silang, embun di cermin mulai menghilang. Pesan lain pun terungkap…"

#game/script.rpy:1711
translate id_zenpy puzzle_24_b5e0fd7a:

#   "Barkimedes leads the way. Together you follow the burglars' footprints from the bedroom into the passage."
    "Barkimedes memimpin jalan. Bersama-sama kalian mengikuti jejak kaki para pencuri dari kamar tidur ke lorong."

#game/script.rpy:1712
translate id_zenpy puzzle_24_189a2512:

#   "The passage twists and turns. You pass dozens more rooms, but they are all empty."
    "Lorong itu berkelok-kelok. Kamu melewati belasan ruangan lagi, tapi semuanya kosong."

#game/script.rpy:1713
translate id_zenpy puzzle_24_f95b160b:

#   "The passage finally ends at an old wooden door, leading to the turrets."
    "Lorong itu akhirnya berujung di sebuah pintu kayu tua yang menuju ke menara-menara."

#game/script.rpy:1715
translate id_zenpy puzzle_24_aa07dae4:

#   "The door is locked! But you have the old iron key."
    "Pintunya terkunci! Tapi kamu punya kunci besi lama itu."

#game/script.rpy:1727
translate id_zenpy loud_alarm_sound_563e5d27:

#   "You've set the clock to the wrong time! Its alarm starts to sound loudly."
    "Kamu menyetel jam ke waktu yang salah! Alarmnya berbunyi keras."

#game/script.rpy:1728
translate id_zenpy loud_alarm_sound_041f0a3f:

#   "The burglars will hear it! Quickly, you take a pillow from the bed and muffle the sound until it stops. '1:30' is the same as 'half-past one'."
    "Para pencuri pasti mendengarnya! Dengan cepat, kamu mengambil bantal dari tempat tidur dan meredam suaranya sampai berhenti. '1:30' sama artinya dengan 'setengah dua'."

#game/script.rpy:1737
translate id_zenpy puzzle_25_682856a9:

#   "You take the key from your bag and fit it in the keyhole."
    "Kamu mengambil kunci dari tasmu dan memasukkannya ke dalam lubang kunci."

#game/script.rpy:1750
translate id_zenpy puzzle_25_a9394597:

#   "You used the correct item."
    "Kamu menggunakan benda yang tepat."

#game/script.rpy:1754
translate id_zenpy puzzle_25_35f107f1:

#   "That doesn't work."
    "Itu tidak berhasil."

#game/script.rpy:1757
translate id_zenpy puzzle_25_f514b538:

#   "It's stiff but you manage to turn it."
    "Kuncinya agak keras, tapi kamu berhasil memutarnya."

#game/script.rpy:1762
translate id_zenpy puzzle_25_a5270216:

#   "A short flight of steps climbs to a circular room. Four passageways lead from the room at right angles to each other."
    "Beberapa anak tangga naik ke sebuah ruangan berbentuk lingkaran. Empat lorong keluar dari ruangan itu dan saling membentuk sudut siku-siku."

#game/script.rpy:1763
translate id_zenpy puzzle_25_d4825167:

#   "The passages lead to the turrets! But which is which?"
    "Lorong-lorong itu menuju ke menara-menara! Tapi yang mana menuju ke mana?"

#game/script.rpy:1764
translate id_zenpy puzzle_25_f2f651e3:

#   "Then you see it! There is a pyramid-shaped hole at the centre of the floor."
    "Lalu kamu melihatnya! Ada lubang berbentuk piramida di tengah lantai."

#game/script.rpy:1765
translate id_zenpy puzzle_25_a7f2eb51:

#   "Just like the one in the garden! You take the pyramid from your bag and drop it into the hole with the sun picture on the correct side."
    "Sama seperti yang di taman! Kamu mengambil piramida dari tasmu dan memasukkannya ke dalam lubang dengan gambar matahari di sisi yang benar."

#game/script.rpy:1784
translate id_zenpy puzzle_25_d0cd9bc3:

#   "That's not the item needed."
    "Itu bukan benda yang dibutuhkan."

#game/script.rpy:1786
translate id_zenpy puzzle_25_13414ce4:

#   "Now you can go to the correct turret! Which do you choose?"
    "Sekarang kamu bisa pergi ke menara yang benar! Yang mana yang kamu pilih?"

#game/script.rpy:1780
translate id_zenpy puzzle_25_a9394597_1:

#   "You used the correct item."
    "Kamu menggunakan benda yang tepat."

#game/script.rpy:1806
translate id_zenpy scalding_water_15a4d6f2:

#   "As you add a nought to the pattern, the bathroom begins to fill with steam."
    "Saat kamu menambahkan lingkaran ke polanya, kamar mandi mulai dipenuhi uap."

#game/script.rpy:1807
translate id_zenpy scalding_water_6052f5ab:

#   "The taps gush scalding water. You can't turn them off! The door is locked you cannot escape!"
    "Keran-keran menyemburkan air mendidih. Kamu tidak bisa mematikannya! Pintunya terkunci — kamu tidak bisa melarikan diri!"

#game/script.rpy:1811
translate id_zenpy scalding_water_d0eac817:

#   "Then there is a loud crash. It's Barkimedes! He has broken through the door. He has a large spanner in his mouth. You use the spanner to turn off the taps."
    "Lalu terjadi dentuman keras. Barkimedes! Ia mendobrak pintu. Di mulutnya ada kunci pas besar. Kamu menggunakan kunci pas itu untuk mematikan keran."

#game/script.rpy:1812
translate id_zenpy scalding_water_0a7b6c5d:

#   "Adding the nought did not make the pattern symmetrical. There are now more noughts on the right than on the left."
    "Menambahkan lingkaran tidak membuat polanya menjadi simetris. Sekarang ada lebih banyak lingkaran di sisi kanan daripada di sisi kiri."

#game/script.rpy:1819
translate id_zenpy topple_into_empty_space_2fc87f89:

#   "You set off along the passage and spot another door. It must lead into the turret."
    "Kamu berjalan menyusuri lorong dan melihat pintu lain. Pasti itu menuju ke menara."

#game/script.rpy:1823
translate id_zenpy topple_into_empty_space_cc43a80a:

#   "You open it, but there is no floor! You start to topple over into empty space. But Barkimedes grabs your shirt with his teeth and pulls you back."
    "Kamu membukanya, tapi tidak ada lantai di baliknya! Kamu mulai terjatuh ke ruang kosong yang menganga. Tapi Barkimedes mencengkeram bajumu dengan giginya dan menarikmu kembali."

#game/script.rpy:1826
translate id_zenpy topple_into_empty_space_5493a9d7:

#   "You took the wrong passage. With the compass points facing this way, turret Y is to the north-east."
    "Kamu mengambil lorong yang salah. Dengan arah mata angin menghadap ke sini, menara Y berada di sebelah timur laut."

#game/script.rpy:1835
translate id_zenpy puzzle_26_53645af1:

#   "You set off along the passage. Soon you see footprints. You are going in the right direction! At the end of the passage you find a door."
    "Kamu berjalan menyusuri lorong. Tak lama kemudian kamu melihat jejak kaki. Kamu sedang menuju ke arah yang benar! Di ujung lorong kamu menemukan sebuah pintu."

#game/script.rpy:1839
translate id_zenpy puzzle_26_097e0ee6:

#   "It opens onto a spiral staircase. You saw the light at the top of the turret, so you climb up."
    "Pintu itu terbuka ke tangga spiral. Kamu melihat cahaya di bagian atas menara, jadi kamu mulai naik."

#game/script.rpy:1843
translate id_zenpy puzzle_26_5ff6bdfa:

#   "You're getting so used to all this maths that you decide to count the stairs as you climb. There are exactly 28. The staircase ends at another door."
    "Kamu sudah terbiasa dengan semua matematika ini, jadi kamu memutuskan untuk menghitung anak tangga sambil naik. Ternyata tepat 28 anak tangga. Tangga itu berakhir di pintu lain."

#game/script.rpy:1849
translate id_zenpy puzzle_26_2652add1:

#   "There is a note pinned to the wood. You read it carefully…"
    "Ada sebuah catatan yang ditempel di kayu pintu. Kamu membacanya dengan seksama…"

#game/script.rpy:1850
translate id_zenpy puzzle_26_8fa5e0fc:

#   "There are two handles on the door, one labelled January, the other February."
    "Ada dua gagang di pintu itu, satu berlabel Januari dan satu lagi berlabel Februari."

#game/script.rpy:1864
translate id_zenpy puzzle_26_08c88eea:

#   "You grip the February handle and turn it."
    "Kamu memegang gagang Februari dan memutarnya."

#game/script.rpy:1867
translate id_zenpy puzzle_26_74705590:

#   "The door opens. You had remembered the old rhyme..."
    "Pintunya terbuka. Kamu mengingat sajak lama itu..."

#game/script.rpy:1871
translate id_zenpy puzzle_26_9f64babf:

#   "You step inside, ready to face the burglars. Barkimedes is with you."
    "Kamu melangkah masuk, siap menghadapi para pencuri. Barkimedes ada bersamamu."

#game/script.rpy:1882
translate id_zenpy flames_spurt_afdda9ec:

#   "The January handle comes away in your hand! The door starts to shake. Smoke and flames spurt from the edges."
    "Gagang Januari itu lepas di tanganmu! Pintu mulai bergetar. Asap dan api menyembur dari tepi-tepinya."

#game/script.rpy:1883
translate id_zenpy flames_spurt_1aef0f06:

#   "Quickly you place the handle back in position. How many days are there in January? How many in February?"
    "Dengan cepat kamu mengembalikan gagangnya ke tempatnya. Ada berapa hari di bulan Januari? Ada berapa di bulan Februari?"

#game/script.rpy:1892
translate id_zenpy puzzle_27_a501fd91:

#   "The room is empty! There is just a lamp standing on a table next to a hastily written letter…"
    "Ruangannya kosong! Hanya ada sebuah lampu yang berdiri di meja di samping surat yang ditulis dengan tergesa-gesa…"

#game/script.rpy:1896
translate id_zenpy puzzle_27_8f706b6c:

#   "As fast as you can you race down the stairs, counting as you go... three hundred and sixty, three hundred and sixty one, three hundred and sixty two…"
    "Secepat yang bisa, kamu berlari menuruni tangga sambil terus menghitung... tiga ratus enam puluh, tiga ratus enam puluh satu, tiga ratus enam puluh dua…"

#game/script.rpy:1908
translate id_zenpy puzzle_27_f44b285b:

#   "You reach step 365 and stop. There is a door on your left. This must be it! You listen for a moment."
    "Kamu mencapai anak tangga ke-365 dan berhenti. Ada sebuah pintu di sebelah kirimu. Pasti ini dia! Kamu mendengarkan sejenak."

#game/script.rpy:1910
translate id_zenpy puzzle_27_2868c863:

#   "There are voices inside!"
    "Ada suara-suara dari dalam!"

#game/script.rpy:1911
translate id_zenpy puzzle_27_6cbf19d1:

#   "Taking a deep breath you open the door and step through. Barkimedes is by your side."
    "Kamu menarik napas dalam-dalam, membuka pintu, dan melangkah masuk. Barkimedes ada di sisimu."

#game/script.rpy:1920
translate id_zenpy puzzle_27_120583c5:

#   "You reach step 366 and stop. There is a door on the right. This must be it! You listen for a moment."
    "Kamu mencapai anak tangga ke-366 dan berhenti. Ada sebuah pintu di sebelah kananmu. Pasti ini dia! Kamu mendengarkan sejenak."

#game/script.rpy:1922
translate id_zenpy puzzle_27_28dc6736:

#   "There are voices inside! Taking a deep breath you open the door and step through. Barkimedes is with you."
    "Ada suara-suara dari dalam! Kamu menarik napas dalam-dalam, membuka pintu, dan melangkah masuk. Barkimedes bersamamu."

#game/script.rpy:1930
translate id_zenpy puzzle_28_0b6196c1:

#   "There are three people in the room. A man and woman are standing. A second man is tied up in a chair."
    "Ada tiga orang di ruangan itu. Seorang pria dan seorang wanita sedang berdiri. Seorang pria lain terikat di kursi."

#game/script.rpy:1931
translate id_zenpy puzzle_28_cc880c4c:

#   "The two men look identical! At first the standing man and woman look shocked. Then the man tries to smile."
    "Kedua pria itu terlihat persis sama! Awalnya pria dan wanita yang berdiri itu tampak terkejut. Kemudian pria itu mencoba tersenyum."

#game/script.rpy:1932
translate id_zenpy puzzle_28_dfb9c321:

#   c "Thank goodness you're here!"
    c "Syukurlah kamu datang!"

#game/script.rpy:1933
translate id_zenpy puzzle_28_6e69e9b2:

#   c "I am the owner of the Mansion and this is my cook. We caught the burglar and tied him up. He is my butler. He has disguised himself to look like me."
    c "Aku adalah pemilik Mansion dan ini adalah juru masakku. Kami menangkap pencuri ini dan mengikatnya. Dia adalah kepala pelayanku. Dia menyamar agar terlihat seperti aku."

#game/script.rpy:1934
translate id_zenpy puzzle_28_c0532c5d:

#   "The woman smiles, she has a gap in her teeth!"
    "Wanita itu tersenyum — giginya ada yang ompong!"

#game/script.rpy:1935
translate id_zenpy puzzle_28_e874b735:

#   w "That's right,"
    w "Betul sekali,"

#game/script.rpy:1936
translate id_zenpy puzzle_28_fc76a190:

#   w "He was about to get away. If you guard him, we'll fetch the police!"
    w "Dia hampir berhasil kabur. Kalau kamu menjaganya, kami akan pergi memanggil polisi!"

#game/script.rpy:1937
translate id_zenpy puzzle_28_7c9c902d:

#   "Then the man in the chair speaks."
    "Lalu pria yang terikat di kursi itu pun berbicara."

#game/script.rpy:1938
translate id_zenpy puzzle_28_e2c988de:

#   t "Don't listen to them,"
    t "Jangan dengarkan mereka,"

#game/script.rpy:1939
translate id_zenpy puzzle_28_1fb1556c:

#   t "I'm the owner of the Mansion. I've been leaving you notes. These criminals are my butler and cook!"
    t "Akulah pemilik Mansion yang sebenarnya. Aku yang meninggalkan catatan-catatan untukmu. Orang-orang itulah penjahatnya — kepala pelayan dan juru masakku!"

#game/script.rpy:1940
translate id_zenpy puzzle_28_f044f123:

#   "Who should you believe?"
    "Siapa yang harus kamu percaya?"

#game/script.rpy:1941
translate id_zenpy puzzle_28_317266e3:

#   "Then you remember the clues you have collected along the way. You ask the two men to hold out a hand and to take off a shoe. This is what you see…"
    "Lalu kamu mengingat petunjuk-petunjuk yang telah kamu kumpulkan. Kamu meminta kedua pria itu untuk mengulurkan tangan dan melepas sepatu mereka. Inilah yang kamu lihat…"

#game/script.rpy:1951
translate id_zenpy puzzle_28_a7170935:

#   "The clues confirm the truth!"
    "Petunjuk-petunjuknya membuktikan kebenarannya!"

#game/script.rpy:1952
translate id_zenpy puzzle_28_c9bdd9d0:

#   "The burglars have captured the owner and tied him up! As Barkimedes stands guard over the two criminals you untie the prisoner."
    "Para pencurilah yang menangkap pemilik Mansion dan mengikatnya! Saat Barkimedes menjaga kedua penjahat itu, kamu melepaskan ikatan sang pemilik."

#game/script.rpy:1953
translate id_zenpy puzzle_28_b404ada4:

#   "The owner explains the burglars' plot."
    "Sang pemilik menjelaskan rencana jahat para pencuri itu."

#game/script.rpy:1954
translate id_zenpy puzzle_28_8c14e841:

#   "The butler and the cook were going to keep him prisoner in the cellar. The butler would pretend to be him when the police came."
    "Kepala pelayan dan juru masak itu berencana menahannya sebagai tawanan di gudang bawah. Sang kepala pelayan akan berpura-pura menjadi pemilik Mansion saat polisi datang."

#game/script.rpy:1955
translate id_zenpy puzzle_28_0a4fc6a5:

#   "After the police had failed to solve the crime, the criminals would take the paintings and jewellery from their hiding places, and make their getaway!"
    "Setelah polisi gagal memecahkan kasus ini, para penjahat itu berencana mengambil lukisan dan perhiasan dari tempat persembunyiannya, lalu kabur!"

#game/script.rpy:1962
translate id_zenpy empty_room_with_fire_3c5b2a9f:

#   "The room is empty! The sound of voices is coming through an air vent. The door slams behind you."
    "Ruangannya kosong! Suara-suara itu ternyata berasal dari ventilasi udara. Pintu terbanting menutup di belakangmu."

#game/script.rpy:1968
translate id_zenpy empty_room_with_fire_895fd81c:

#   "Then you hear a rumble. The stone floor is sliding to one side. There is a pit of fire below. Soon you will fall into it!"
    "Lalu kamu mendengar suara gemuruh. Lantai batu itu mulai bergeser ke samping. Di bawahnya ada lubang api yang menyala. Sebentar lagi kamu akan jatuh ke dalamnya!"

#game/script.rpy:1969
translate id_zenpy empty_room_with_fire_166cac6b:

#   "Quickly you take the pyramid from your bag. You jam one edge into the crack between the floor and the wall perhaps it will work as a wedge?"
    "Dengan cepat kamu mengambil piramida dari tasmu. Kamu mengganjal salah satu rusuknya ke celah antara lantai dan dinding — mungkin bisa berfungsi sebagai pengganjal?"

#game/script.rpy:1970
translate id_zenpy empty_room_with_fire_e4174bf0:

#   "With a groan and a creak the floor stops moving. Now you must escape."
    "Dengan suara gerutu dan derit, lantai itu berhenti bergerak. Sekarang kamu harus melarikan diri."

#game/script.rpy:1971
translate id_zenpy empty_room_with_fire_b6e4aaf3:

#   "Barkimedes spots a way out. He grabs a loose plank in the door with his jaws and pulls it free. You both crawl through the gap."
    "Barkimedes menemukan jalan keluar. Ia mencengkeram papan yang longgar di pintu dengan rahangnya dan menariknya hingga lepas. Kalian berdua merangkak melewati celah itu."

#game/script.rpy:1974
translate id_zenpy empty_room_with_fire_44becd2e:

#   "There are 366 days in a leap year. How many days in a normal year?"
    "Ada 366 hari dalam satu tahun kabisat. Berapa hari dalam satu tahun biasa?"

#game/script.rpy:1983
translate id_zenpy wrong_man_35f82c4e:

#   "You start to tell the man and woman to call the police, but Barkimedes barks fiercely. The man and the woman back into a corner."
    "Kamu mulai menyuruh pria dan wanita itu untuk memanggil polisi, tapi Barkimedes menggonggong dengan keras. Pria dan wanita itu mundur ke sudut ruangan."

#game/script.rpy:1985
translate id_zenpy wrong_man_2614f05a:

#   "Look again at the clues. The man who is standing has a missing button and a scar on his hand."
    "Lihat lagi petunjuk-petunjuknya. Pria yang sedang berdiri itu memiliki kancing yang hilang dan ada bekas luka di tangannya."

#game/script.rpy:1986
translate id_zenpy wrong_man_b4fe35df:

#   "The pattern on his shoe matches the one in the flour. His accomplice, the cook, has a gap in her teeth!"
    "Pola di sepatunya cocok dengan jejak di tepung tadi. Dan rekannya, si juru masak, giginya ompong!"

#game/script.rpy:1994
translate id_zenpy criminals_catched_8a4edf80:

#   "Now it is the criminals' turn to be tied up."
    "Kini giliran para penjahat yang diikat."

#game/script.rpy:1995
translate id_zenpy criminals_catched_9eb2a4c5:

#   "While you phone the police station and gather the stolen goods as evidence, the owner leads the butler and the cook into the Grand Hall and ties them to two chairs."
    "Sementara kamu menelepon kantor polisi dan mengumpulkan barang curian sebagai bukti, sang pemilik membawa kepala pelayan dan juru masak ke Aula Besar dan mengikat mereka di dua kursi."

#game/script.rpy:1997
translate id_zenpy criminals_catched_aa0d5e4c:

#   "Barkimedes growls at them angrily, they are too scared of him to try and escape!"
    "Barkimedes menggeram marah ke arah mereka — mereka terlalu takut padanya untuk mencoba melarikan diri!"

#game/script.rpy:1998
translate id_zenpy criminals_catched_ba8bb9ab:

#   "The owner smiles when he sees his belongings safe and sound."
    "Sang pemilik tersenyum lega ketika melihat barang-barangnya kembali utuh dan aman."

#game/script.rpy:1999
translate id_zenpy criminals_catched_40331dfd:

#   o "I can't thank you enough,"
    o "Aku tidak tahu harus berterima kasih seperti apa,"

#game/script.rpy:2000
translate id_zenpy criminals_catched_a2a25a4d:

#   o "Some of these things have been in my family for generations, they are priceless to me."
    o "Beberapa benda ini sudah ada di keluargaku selama turun-temurun. Nilainya tak ternilai bagiku."

#game/script.rpy:2002
translate id_zenpy criminals_catched_fbb92c04:

#   "Barkimedes barks happily and wags his tail. You crouch down to pat him on the head."
    "Barkimedes menggonggong gembira dan mengibas-ngibaskan ekornya. Kamu berjongkok untuk mengelus kepalanya."

#game/script.rpy:2003
translate id_zenpy criminals_catched_eab3e15e:

#   "You are not the only one to thank you couldn't have done it without Barkimedes."
    "Kamu juga harus berterima kasih — kamu tidak akan berhasil tanpa bantuan Barkimedes."

#game/script.rpy:2004
translate id_zenpy criminals_catched_a92b4ef3:

#   y "You may need a new butler and cook,"
    y "Mungkin kamu butuh kepala pelayan dan juru masak yang baru,"

#game/script.rpy:2005
translate id_zenpy criminals_catched_fea65803:

#   y "But you'll never need another dog!"
    y "Tapi kamu tidak akan pernah butuh anjing lain!"

#game/script.rpy:2007
translate id_zenpy criminals_catched_9b59eb41:

#   "- The End -"
    "- Tamat -"
